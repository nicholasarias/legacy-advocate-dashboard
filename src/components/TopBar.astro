<div class="w-full border-b border-gray-800 bg-gray-900 px-6 py-4 text-white">
  <div class="flex flex-col gap-4 2xl:flex-row 2xl:items-end 2xl:justify-between">
    <div class="flex flex-wrap items-end gap-4">
      <div class="min-w-[200px]">
        <label for="clientName" class="form-label">Client Name</label>
        <input id="clientName" type="text" placeholder="Enter name" class="form-input" />
      </div>

      <div class="min-w-[90px]">
        <label for="clientState" class="form-label">State</label>
        <input id="clientState" type="text" placeholder="OK" class="form-input uppercase" />
      </div>

      <div class="min-w-[200px]">
        <label for="beneficiaryName" class="form-label">Beneficiary</label>
        <input id="beneficiaryName" type="text" placeholder="Beneficiary" class="form-input" />
      </div>

      <div class="min-w-[140px]">
        <span class="form-label">Call Timer</span>
        <div
          id="call-timer"
          class="rounded-lg border border-gray-700 bg-gray-800 px-3 py-2 text-sm font-semibold text-white"
        >
          00:00
        </div>
      </div>

      <div class="min-w-[140px]">
        <label for="premiumInput" class="form-label">Premium</label>
        <input id="premiumInput" type="text" placeholder="55.00" class="form-input" />
      </div>

      <div class="min-w-[140px]">
        <label for="draftDateInput" class="form-label">Draft Date</label>
        <input id="draftDateInput" type="text" placeholder="15th" class="form-input" />
      </div>
    </div>

    <div class="rounded-xl border border-gray-800 bg-gray-950 px-4 py-3 text-left">
      <div id="advisor-display-name" class="text-sm font-semibold">Nick Arias</div>
      <div class="text-xs text-gray-400">
        Phone:
        <span id="advisor-display-phone">YOUR_PHONE</span>
      </div>
      <div class="text-xs text-gray-400">
        NPN:
        <span id="advisor-display-npn">YOUR_NPN</span>
      </div>
    </div>
  </div>
</div>
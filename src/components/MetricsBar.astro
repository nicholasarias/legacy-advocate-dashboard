<div class="w-full border-b border-gray-800 bg-gray-950 px-6 py-3 text-sm text-gray-200">
  <div class="flex flex-wrap items-center gap-6">
    <div>
      <span class="text-gray-400">Transfers</span>
      <span id="transfers-count" class="ml-1 font-semibold">0</span>
    </div>

    <div>
      <span class="text-gray-400">Sales</span>
      <span id="sales-count" class="ml-1 font-semibold">0</span>
    </div>

    <div>
      <span class="text-gray-400">Close %</span>
      <span id="close-rate" class="ml-1 font-semibold">0%</span>
    </div>

    <div>
      <span class="text-gray-400">Sales Goal</span>
      <span id="sales-goal-progress" class="ml-1 font-semibold">0</span>
      <span class="text-gray-500">/</span>
      <span id="sales-goal-target" class="font-semibold">8</span>
    </div>

    <div>
      <span class="text-gray-400">AP</span>
      <span id="ap-submitted" class="ml-1 font-semibold">$0.00</span>
      <span class="text-gray-500">/</span>
      <span id="ap-goal-target" class="font-semibold">$3000.00</span>
    </div>
  </div>

  <div class="mt-3 flex flex-wrap gap-4 text-xs">
    <div class="metric-pill border border-emerald-500/30 bg-emerald-500/10 text-emerald-300">
      Sold: <span id="sold-count" class="font-semibold">0</span>
    </div>

    <div class="metric-pill border border-sky-500/30 bg-sky-500/10 text-sky-300">
      Callback: <span id="callback-count" class="font-semibold">0</span>
    </div>

    <div class="metric-pill border border-gray-500/30 bg-gray-500/10 text-gray-300">
      Not Interested: <span id="not-interested-count" class="font-semibold">0</span>
    </div>

    <div class="metric-pill border border-amber-500/30 bg-amber-500/10 text-amber-300">
      Medical DQ: <span id="medical-dq-count" class="font-semibold">0</span>
    </div>
  </div>
</div>

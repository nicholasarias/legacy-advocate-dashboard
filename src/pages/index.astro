    outcomeCallbackButton?.addEventListener("click", () => {
      setOutcome("Callback");
    });

    outcomeNotInterestedButton?.addEventListener("click", () => {
      setOutcome("Not Interested");
    });

    outcomeMedicalDQButton?.addEventListener("click", () => {
      setOutcome("Medical DQ");
    });

    objectionSearch?.addEventListener("input", () => {
      filterRebuttals(objectionSearch.value);
    });

    toggleShortcutsButton?.addEventListener("click", () => {
      shortcutsPanel?.classList.toggle("hidden");
    });

    toggleObjectionsButton?.addEventListener("click", () => {
      showObjectionsPanel(true);
    });

    closeObjectionsButton?.addEventListener("click", () => {
      hideObjectionsPanel();
    });

    openSettingsButton?.addEventListener("click", () => {
      openSettings();
    });

    closeSettingsButton?.addEventListener("click", () => {
      closeSettings();
    });

    saveSettingsButton?.addEventListener("click", () => {
      saveSettingsFromForm();
    });

    settingsModal?.addEventListener("click", (event) => {
      if (event.target === settingsModal) {
        closeSettings();
      }
    });

    window.addEventListener("keydown", (event) => {
      const typing = isTypingInField(event.target);

      if (event.ctrlKey && event.key.toLowerCase() === "n") {
        event.preventDefault();
        clearCallSession();
        return;
      }

      if (event.ctrlKey && event.key.toLowerCase() === "s") {
        event.preventDefault();
        addSale(false);
        return;
      }

      if (event.altKey && event.key.toLowerCase() === "c") {
        event.preventDefault();
        clientNameInput?.focus();
        return;
      }

      if (event.altKey && event.key.toLowerCase() === "b") {
        event.preventDefault();
        beneficiaryNameInput?.focus();
        return;
      }

      if (!typing && event.key === "ArrowRight") {
        event.preventDefault();
        goToAdjacentSection(1);
        return;
      }

      if (!typing && event.key === "ArrowLeft") {
        event.preventDefault();
        goToAdjacentSection(-1);
      }
    });

    updateSettingsUI();
    updateTimerDisplay();
    updateMetrics();
    updateOutcomeDisplay();
    renderRebuttalList(rebuttals.slice(0, 10));
    selectRebuttal(1);
    renderSection(currentSection);
  </script>
</Layout>

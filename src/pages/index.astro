        return {
          key: "familyContextNotes",
          label: "Family Notes",
          placeholder: "Anything important about family dynamics or who matters most"
        };
      }

      if (section.id === 4) {
        return {
          key: "lossExperienceNotes",
          label: "Loss Notes",
          placeholder: "Who was lost, who handled things, and what felt hardest"
        };
      }

      if (section.id === 5) {
        return {
          key: "familyResponsibilityNotes",
          label: "90-Day Window Notes",
          placeholder: "Capture what those first few months would look like"
        };
      }

      if (section.id === 6) {
        return {
          key: "currentSupportNotes",
          label: "Support Notes",
          placeholder: "What is already set aside and where the pressure still lands"
        };
      }

      if (section.id >= 7 && section.id <= 10) {
        return {
          key: "protectionPriorityNotes",
          label: "Bridge Notes",
          placeholder: "Capture the one pressure point you want to carry into the bridge"
        };
      }

      return null;
    }

    function getDiscoveryNotesFieldByKey(key) {
      if (key === "familyContextNotes") return familyContextNotesInput;
      if (key === "lossExperienceNotes") return lossExperienceNotesInput;
      if (key === "familyResponsibilityNotes") return familyResponsibilityNotesInput;
      if (key === "currentSupportNotes") return currentSupportNotesInput;
      if (key === "protectionPriorityNotes") return protectionPriorityNotesInput;
      return null;
    }

    function updateDiscoveryInlineNotes(section) {
      if (!discoveryInlineNotesShell || !discoveryInlineNotesInput || !discoveryInlineNotesLabel) {
        return;
      }

      const notesConfig = getDiscoveryNotesConfig(section);

      if (!isDiscoverySection(section) || !notesConfig) {
        discoveryInlineNotesShell.classList.add("hidden");
        discoveryInlineNotesInput.dataset.discoveryKey = "";
        return;
      }

      discoveryInlineNotesShell.classList.remove("hidden");
      discoveryInlineNotesLabel.textContent = notesConfig.label;
      discoveryInlineNotesInput.placeholder = notesConfig.placeholder;
      discoveryInlineNotesInput.dataset.discoveryKey = notesConfig.key;
      discoveryInlineNotesInput.value = sessionState.discovery?.[notesConfig.key] || "";
    }

    function updateDiscoveryFocusCard(section) {
      const discoveryActive = isDiscoverySection(section);

      workflowGrid?.classList.toggle("workflow-grid-discovery", discoveryActive);
      scriptPanel?.classList.toggle("script-panel-discovery", discoveryActive);
      secondaryRail?.classList.toggle("secondary-rail-discovery", discoveryActive);

      quietDuringDiscoveryPanels.forEach((panel) => {
        panel.classList.toggle("panel-quiet", discoveryActive);
      });

      promptPanel?.classList.toggle("panel-quiet-soft", discoveryActive);

      if (!discoveryFocusShell || !discoveryPacingCue || !discoveryFocusTitle) {
        updateDiscoveryInlineNotes(section);
        return;
      }

      if (!discoveryActive) {
        discoveryFocusShell.classList.add("hidden");
        updateDiscoveryInlineNotes(section);
        return;
      }

      discoveryFocusShell.classList.remove("hidden");
      discoveryFocusTitle.textContent = section.title;
      discoveryPacingCue.textContent = getPrimaryPacingCue(section);
      updateDiscoveryInlineNotes(section);
    }

    function hideDiscoveryGroups() {
      [
        familyContextGroup,
        lossExperienceGroup,
        familyResponsibilityGroup,
        currentSupportGroup,
        protectionPriorityGroup,
        discoveryBridgeGroup
      ].forEach((group) => {

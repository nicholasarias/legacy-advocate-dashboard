    function formatTime(totalSeconds) {
      const minutes = Math.floor(totalSeconds / 60);
      const seconds = totalSeconds % 60;
      return `${String(minutes).padStart(2, "0")}:${String(seconds).padStart(2, "0")}`;
    }

    function normalizeObjectionSignalText(value) {
      return String(value || "")
        .toLowerCase()
        .replace(/[^a-z0-9\s]/g, " ")
        .replace(/\s+/g, " ")
        .trim();
    }

    function tokenSetFromText(value) {
      return new Set(normalizeObjectionSignalText(value).split(" ").filter(Boolean));
    }

    function tokenSetHasAny(tokenSet, values) {
      return values.some((value) => tokenSet.has(value));
    }

    function getObjectionTriggerMatcherScore(definition, tokenSet) {
      if (definition.matcher === "spouse-talk") {
        return tokenSetHasAny(tokenSet, TALK_SIGNAL_WORDS) && tokenSetHasAny(tokenSet, SPOUSE_SIGNAL_WORDS) ? 3 : 0;
      }

      if (definition.matcher === "family-talk") {
        return tokenSetHasAny(tokenSet, TALK_SIGNAL_WORDS) && tokenSetHasAny(tokenSet, FAMILY_SIGNAL_WORDS) ? 3 : 0;
      }

      return 0;
    }

    function findMatchingObjectionTrigger(text, source = "notes") {
      const normalizedText = normalizeObjectionSignalText(text);
      if (!normalizedText) return null;

      const tokenSet = tokenSetFromText(normalizedText);
      const threshold = source === "search" ? 1 : 3;
      const currentStageGroup = getObjectionStageGroup();
      let bestMatch = null;

      objectionTriggerDefinitions.forEach((definition) => {
        if (!definition.rebuttalIds?.[currentStageGroup]) {
          return;
        }

        let score = 0;

        (definition.phrases || []).forEach((phrase) => {
          if (normalizedText.includes(phrase)) {
            score += 3;
          }
        });

        (definition.terms || []).forEach((term) => {
          if (tokenSet.has(term)) {
            score += 1;
          }
        });

        score += getObjectionTriggerMatcherScore(definition, tokenSet);

        if (!bestMatch || score > bestMatch.score) {
          bestMatch = {
            definition,
            score
          };
        }
      });

      if (!bestMatch || bestMatch.score < threshold) {
        return null;
      }

      return bestMatch.definition;
    }


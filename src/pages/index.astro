      discoveryWorkspacePanel.classList.remove("hidden");
      hideDiscoveryGroups();
      setImpactCardSelectionUI(sessionState.discovery?.primaryConcern || "");
      updateBridgePrioritySummary();

      if (sectionId === 2) {
        discoveryPanelTitle.textContent = "Family & Life Context";
        discoveryPanelText.textContent =
          "Keep this conversational and listen for who matters most.";
        familyContextGroup?.classList.remove("hidden");
        return;

---
import Layout from "../layouts/Layout.astro";
import TopBar from "../components/TopBar.astro";
import MetricsBar from "../components/MetricsBar.astro";
import { scriptSections } from "../data/scriptSections";
import { rebuttals } from "../data/rebuttals";

const firstSection = scriptSections[0];
const favoriteRebuttals = rebuttals.filter((item) => item.favorite);
---

<Layout>
  <TopBar />
  <MetricsBar />

  <main class="flex min-h-[calc(100vh-150px)] flex-col lg:flex-row">
    <aside class="w-full border-r border-gray-800 bg-gray-900 text-white lg:w-72 xl:w-80">
      <div class="border-b border-gray-800 px-4 py-4">
        <div class="flex items-center justify-between gap-3">
          <div>
            <h2 class="text-lg font-semibold">Script Sections</h2>
            <p class="text-xs text-gray-400">
              <span id="progress-text">1 / 24</span>
            </p>
          </div>
        </div>

        <div class="mt-3 h-2 overflow-hidden rounded-full bg-gray-800">
          <div id="progress-bar" class="h-full w-[4%] bg-sky-500"></div>
        </div>
      </div>

      <nav id="sidebar-nav" class="max-h-[calc(100vh-230px)] overflow-y-auto p-2">
        <ul class="space-y-1">
          {scriptSections.map((section) => (
            <li>
              <button
                class:list={[
                  "section-button w-full rounded-lg px-3 py-3 text-left text-sm transition",
                  section.id === firstSection.id ? "sidebar-button-active" : "sidebar-button-idle"
                ]}
                data-section-id={section.id}
                type="button"
              >
                <span class="block font-medium">
                  {section.id}. {section.title}
                </span>

                {section.qaRequired && (
                  <span class="mt-1 inline-block text-xs text-amber-400">
                    Verbatim Required
                  </span>
                )}
              </button>
            </li>
          ))}
        </ul>
      </nav>
    </aside>

    <section class="flex-1 bg-gray-950 text-white">
      <div class="border-b border-gray-800 px-8 py-6">
        <div class="flex flex-col gap-4">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div class="flex flex-wrap items-center gap-3">
              <button id="new-call-button" type="button" class="btn-blue">New Call</button>
              <button id="outcome-sold-button" type="button" class="btn-green">Sold</button>
              <button id="toggle-objections-button" type="button" class="btn">Objections</button>

              <div
                id="qa-badge"
                class:list={[
                  "rounded-full border px-4 py-2 text-sm font-medium",
                  firstSection.qaRequired
                    ? "border-amber-500/40 bg-amber-500/10 text-amber-300"
                    : "hidden"
                ]}
              >
                Verbatim Required
              </div>
            </div>

            <button id="toggle-shortcuts-button" type="button" class="btn">Shortcuts</button>
          </div>

          <div>
            <p id="section-number" class="text-sm uppercase tracking-wide text-gray-400">
              Section {firstSection.id}
            </p>

            <h2 id="section-title" class="mt-1 text-3xl font-bold">
              {firstSection.title}
            </h2>
          </div>
        </div>
      </div>

      <div id="workflow-grid" class="workflow-grid-cockpit p-8">
        <div class="cockpit-flow-group space-y-6">
          <div id="branch-panel" class="panel hidden p-6">
            <div class="space-y-4">
              <div>
                <h3 id="branch-panel-title" class="panel-title !mb-2">Conversation Path</h3>
                <p id="branch-panel-text" class="text-sm text-gray-300">
                  Choose the direction that matches the conversation.
                </p>
              </div>

              <div id="branch-button-group" class="flex flex-wrap gap-3"></div>

              <div id="branch-helper-box" class="hidden rounded-xl border border-gray-800 bg-gray-950 p-4">
                <p class="text-xs uppercase tracking-wide text-gray-500">Current Direction</p>
                <div id="branch-helper-content" class="mt-3 space-y-2 text-sm text-gray-300"></div>
              </div>
            </div>
          </div>

          <div id="objections-panel" class="panel hidden p-6">
            <div class="flex items-center justify-between gap-3">
              <div>
                <h3 class="panel-title !mb-0">Master Rebuttals</h3>
                <p class="mt-2 text-sm text-gray-300">
                  Search, select, and read rebuttals without leaving the main workflow.
                </p>
              </div>
              <button id="close-objections-button" type="button" class="btn">Close</button>
            </div>

            <div class="mt-4">
              <input
                id="objection-search"
                type="text"
                placeholder="Search objections by keyword..."
                class="form-input"
              />
            </div>

            <div class="mt-4">
              <p class="text-xs uppercase tracking-wide text-gray-500">Favorites</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {favoriteRebuttals.map((item) => (
                  <button
                    type="button"
                    class="favorite-rebuttal-button rounded-full border border-gray-700 bg-gray-950 px-3 py-1 text-xs text-gray-200 hover:bg-gray-800"
                    data-rebuttal-id={item.id}
                  >
                    {item.title}
                  </button>
                ))}
              </div>
            </div>

            <div class="mt-4 grid gap-4 xl:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
              <div>
                <p class="text-xs uppercase tracking-wide text-gray-500">Results</p>
                <div id="objection-results" class="mt-3 max-h-80 space-y-2 overflow-y-auto">
                  {rebuttals.slice(0, 10).map((item) => (
                    <button
                      type="button"
                      class="rebuttal-result-button block w-full rounded-lg border border-gray-800 bg-gray-950 px-3 py-2 text-left text-sm text-gray-200 hover:bg-gray-800"
                      data-rebuttal-id={item.id}
                    >
                      <div class="font-semibold">{item.title}</div>
                      <div class="mt-1 text-xs text-gray-400">{item.category}</div>
                    </button>
                  ))}
                </div>
              </div>

              <div class="rounded-xl border border-gray-800 bg-gray-950 p-4">
                <p class="text-xs uppercase tracking-wide text-gray-500">Selected Rebuttal</p>
                <div id="selected-rebuttal-title" class="mt-3 text-sm font-semibold text-white">
                  Select an objection
                </div>
                <div
                  id="selected-rebuttal-body"
                  class="mt-2 whitespace-pre-wrap text-sm leading-6 text-gray-300"
                >
                  Your selected rebuttal will appear here.
                </div>
              </div>
            </div>
          </div>

          <div id="script-panel" class="panel p-8">
            <h3 class="panel-title">Read Aloud Script</h3>
            <div id="discovery-focus-shell" class="discovery-focus-shell hidden">
              <div class="discovery-focus-header">
                <div>
                  <p class="discovery-focus-kicker">Discovery Focus</p>
                  <p id="discovery-reminder" class="discovery-reminder">
                    Listen more than you speak. Let the client answer fully.
                  </p>
                </div>
                <div class="discovery-pacing">
                  <p class="discovery-focus-kicker">Pacing Cue</p>
                  <p id="discovery-pacing-cue" class="discovery-pacing-text">
                    Keep this conversational.
                  </p>
                </div>
              </div>

              <div class="discovery-focus-meta">
                <p class="discovery-focus-kicker">Current Conversation Step</p>
                <p id="discovery-focus-title" class="discovery-focus-title">
                  {firstSection.title}
                </p>
              </div>

              <div class="discovery-visual-cue">
                <p class="discovery-focus-kicker">Visual Cue</p>
                <p class="discovery-visual-cue-text">
                  PAUSE: Let them answer and sit in the silence.
                </p>
              </div>
            </div>
            <div id="script-lines" class="space-y-5 text-xl leading-relaxed text-gray-100">
              {firstSection.script.map((line) => (
                <p>{line}</p>
              ))}
            </div>

            <div id="discovery-inline-notes-shell" class="mt-8 hidden border-t border-gray-800 pt-6">
              <div class="flex items-center justify-between gap-3">
                <div>
                  <p id="discovery-inline-notes-label" class="panel-title !mb-2">Section Notes</p>
                  <p class="text-sm text-gray-400">
                    Capture the key detail in their own words while the section is still fresh.
                  </p>
                </div>
              </div>

              <textarea
                id="discovery-inline-notes-input"
                rows="3"
                placeholder="Capture the key point from this part of the conversation"
                class="form-input mt-4"
              ></textarea>
            </div>
          </div>

          <div id="pricing-action-panel" class="panel hidden p-6">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="panel-title !mb-2">Pricing Workspace</h3>
                <p class="text-sm text-gray-300">
                  Keep pricing, coverage, and rebuttals beside the script while you present numbers.
                </p>
              </div>
            </div>

            <div id="quote-workspace-group" class="mt-5 space-y-3">
              <div class="space-y-3">
                <div class="quote-card" data-quote-card="1">
                  <div class="flex items-center justify-between gap-3">
                    <label for="quote-option-1" class="form-label !mb-0">Option 1</label>
                    <button
                      type="button"
                      class="quote-chip quote-chip-idle"
                      data-recommend-quote="1"
                    >
                      Recommend
                    </button>
                  </div>

                  <div class="mt-3 grid gap-3 sm:grid-cols-2">
                    <div>
                      <label for="coverage-option-1" class="form-label">Coverage</label>
                      <input
                        id="coverage-option-1"
                        type="text"
                        placeholder="10000"
                        class="form-input"
                      />
                    </div>

                    <div>
                      <label for="quote-option-1" class="form-label">Premium</label>
                      <input
                        id="quote-option-1"
                        type="text"
                        placeholder="55.00"
                        class="form-input"
                      />
                    </div>
                  </div>

                  <div class="mt-3 flex justify-end">
                    <button type="button" class="btn" data-use-quote="1">Use As Premium</button>
                  </div>
                </div>

                <div class="quote-card" data-quote-card="2">
                  <div class="flex items-center justify-between gap-3">
                    <label for="quote-option-2" class="form-label !mb-0">Option 2</label>
                    <button
                      type="button"
                      class="quote-chip quote-chip-idle"
                      data-recommend-quote="2"
                    >
                      Recommend
                    </button>
                  </div>

                  <div class="mt-3 grid gap-3 sm:grid-cols-2">
                    <div>
                      <label for="coverage-option-2" class="form-label">Coverage</label>
                      <input
                        id="coverage-option-2"
                        type="text"
                        placeholder="15000"
                        class="form-input"
                      />
                    </div>

                    <div>
                      <label for="quote-option-2" class="form-label">Premium</label>
                      <input
                        id="quote-option-2"
                        type="text"
                        placeholder="69.00"
                        class="form-input"
                      />
                    </div>
                  </div>

                  <div class="mt-3 flex justify-end">
                    <button type="button" class="btn" data-use-quote="2">Use As Premium</button>
                  </div>
                </div>

                <div class="quote-card" data-quote-card="3">
                  <div class="flex items-center justify-between gap-3">
                    <label for="quote-option-3" class="form-label !mb-0">Option 3</label>
                    <button
                      type="button"
                      class="quote-chip quote-chip-idle"
                      data-recommend-quote="3"
                    >
                      Recommend
                    </button>
                  </div>

                  <div class="mt-3 grid gap-3 sm:grid-cols-2">
                    <div>
                      <label for="coverage-option-3" class="form-label">Coverage</label>
                      <input
                        id="coverage-option-3"
                        type="text"
                        placeholder="20000"
                        class="form-input"
                      />
                    </div>

                    <div>
                      <label for="quote-option-3" class="form-label">Premium</label>
                      <input
                        id="quote-option-3"
                        type="text"
                        placeholder="82.00"
                        class="form-input"
                      />
                    </div>
                  </div>

                  <div class="mt-3 flex justify-end">
                    <button type="button" class="btn" data-use-quote="3">Use As Premium</button>
                  </div>
                </div>
              </div>

              <div class="rounded-xl border border-gray-800 bg-gray-950 p-4">
                <p class="text-xs uppercase tracking-wide text-gray-500">Recommended Quote</p>
                <p id="recommended-quote-display" class="mt-2 text-sm text-gray-200">
                  No recommendation selected yet.
                </p>
              </div>
            </div>

            <div id="pricing-objections-group" class="mt-5">
              <p class="text-xs uppercase tracking-wide text-gray-500">Quick Objections</p>
              <div class="mt-3 flex flex-wrap gap-2">
                <button type="button" class="quick-objection-button" data-rebuttal-id="1">
                  Can't Afford It
                </button>
                <button type="button" class="quick-objection-button" data-rebuttal-id="11">
                  Need To Think
                </button>
                <button type="button" class="quick-objection-button" data-rebuttal-id="16">
                  Talk To Spouse
                </button>
                <button type="button" class="quick-objection-button" data-rebuttal-id="21">
                  Has Savings
                </button>
                <button type="button" class="quick-objection-button" data-rebuttal-id="24">
                  Family Will Pay
                </button>
                <button type="button" class="quick-objection-button" data-rebuttal-id="12">
                  Call Back Later
                </button>
              </div>
            </div>

            <div class="mt-5 rounded-xl border border-gray-800 bg-gray-950 p-4">
              <p class="text-xs uppercase tracking-wide text-gray-500">Selected Rebuttal</p>
              <div id="inline-selected-rebuttal-title" class="mt-3 text-sm font-semibold text-white">
                Select an objection
              </div>
              <div
                id="inline-selected-rebuttal-body"
                class="mt-2 whitespace-pre-wrap text-sm leading-6 text-gray-300"
              >
                Your selected rebuttal will appear here.
              </div>
            </div>
          </div>
        </div>

        <div id="secondary-rail" class="cockpit-flow-group self-start space-y-6">
          <div id="advisor-capture-panel" class="panel cockpit-glass-panel p-6">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <h3 class="panel-title !mb-2">Discovery Intake</h3>
                <p class="text-sm text-gray-300">
                  Keep the person, the why, and the current step in one place.
                </p>
              </div>

              <div class="rounded-full border border-emerald-500/25 bg-emerald-500/10 px-3 py-1 text-xs font-semibold text-emerald-300">
                <span id="cockpit-step-readout">Section 1 of 24</span>
              </div>
            </div>

            <div class="mt-5 grid gap-4">
              <div class="grid gap-4 xl:grid-cols-2">
                <div>
                  <label for="cockpit-client-name" class="form-label">Client Name</label>
                  <input
                    id="cockpit-client-name"
                    type="text"
                    placeholder="Client name"
                    class="form-input cockpit-input"
                  />
                </div>

                <div>
                  <label for="cockpit-person-name" class="form-label">Person Who Matters Most</label>
                  <input
                    id="cockpit-person-name"
                    type="text"
                    placeholder="Who are we protecting?"
                    class="form-input cockpit-input"
                  />
                </div>
              </div>

              <div>
                <label for="cockpit-why-input" class="form-label">The Why</label>
                <textarea
                  id="cockpit-why-input"
                  rows="3"
                  placeholder="What would be hardest for them to carry in those first few months?"
                  class="form-input cockpit-input"
                ></textarea>
              </div>

              <div class="cockpit-preview-card rounded-2xl border border-emerald-500/15 bg-emerald-500/5 p-4">
                <p class="text-xs uppercase tracking-wide text-emerald-300">HUD Preview</p>
                <p id="cockpit-hud-preview" class="mt-2 text-sm leading-6 text-emerald-50">
                  What would this mean for the person they care about most?
                </p>
              </div>
            </div>
          </div>

          <div id="prompt-panel" class="panel p-6" data-quiet-during-discovery="true">
            <h3 class="panel-title">Prompts</h3>

            <div class="space-y-4">
              <div>
                <p class="text-xs uppercase tracking-wide text-gray-500">Goal</p>
                <p id="prompt-goal" class="mt-1 text-sm text-gray-200">
                  {firstSection.prompt.goal}
                </p>
              </div>

              <div>
                <p class="text-xs uppercase tracking-wide text-gray-500">Notes</p>
                <div id="prompt-notes" class="mt-2 space-y-2 text-sm text-gray-300">
                  {(firstSection.prompt.notes || []).map((note) => (
                    <p>- {note}</p>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <div id="discovery-workspace-panel" class="panel hidden p-6" data-quiet-during-discovery="true">
            <div>
              <h3 id="discovery-panel-title" class="panel-title !mb-2">Discovery Workspace</h3>
              <p id="discovery-panel-text" class="text-sm text-gray-300">
                Capture family priorities and notes while you listen.
              </p>
            </div>

            <div class="mt-4 rounded-xl border border-sky-500/20 bg-sky-950/20 p-4">
              <p class="text-xs uppercase tracking-wide text-sky-200">Visual Cue</p>
              <p class="mt-2 text-sm text-sky-50">
                PAUSE: Let them answer and sit in the silence.
              </p>
            </div>

            <div id="family-context-group" class="mt-5 hidden space-y-4">
              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <label for="marital-status-input" class="form-label">Marital Status</label>
                  <select id="marital-status-input" class="form-input">
                    <option value="">Select status</option>
                    <option value="married">Married</option>
                    <option value="partnered">Partnered</option>
                    <option value="single">Single</option>
                    <option value="widowed">Widowed</option>
                    <option value="divorced">Divorced</option>
                    <option value="other">Other</option>
                  </select>
                </div>

                <div>
                  <label for="spouse-partner-input" class="form-label">Spouse / Partner</label>
                  <input
                    id="spouse-partner-input"
                    type="text"
                    placeholder="Name or quick note"
                    class="form-input"
                  />
                </div>

                <div>
                  <label for="children-info-input" class="form-label">Children</label>
                  <input
                    id="children-info-input"
                    type="text"
                    placeholder="How many or nearby?"
                    class="form-input"
                  />
                </div>

                <div>
                  <label for="decision-maker-input" class="form-label">Likely Decision Maker</label>
                  <input
                    id="decision-maker-input"
                    type="text"
                    placeholder="Who would handle things?"
                    class="form-input"
                  />
                </div>

                <div>
                  <label for="decision-maker-relation" class="form-label">
                    Decision Maker Relationship
                  </label>
                  <select id="decision-maker-relation" class="form-input">
                    <option value="">Select relationship</option>
                    <option value="spouse">Spouse / Partner</option>
                    <option value="child">Child</option>
                    <option value="sibling">Sibling</option>
                    <option value="friend">Friend / Other</option>
                  </select>
                </div>

                <div>
                  <label for="relies-on-them-input" class="form-label">Who Relies On Them</label>
                  <input
                    id="relies-on-them-input"
                    type="text"
                    placeholder="Financially or practically"
                    class="form-input"
                  />
                </div>
              </div>

              <div>
                <label for="family-context-notes" class="form-label">Notes</label>
                <textarea
                  id="family-context-notes"
                  rows="3"
                  placeholder="Anything important about family dynamics or who matters most"
                  class="form-input"
                ></textarea>
              </div>
            </div>

            <div id="loss-experience-group" class="mt-5 hidden">
              <label for="loss-experience-notes" class="form-label">Notes</label>
              <textarea
                id="loss-experience-notes"
                rows="4"
                placeholder="Who was lost, who handled things, and what felt hardest"
                class="form-input"
              ></textarea>
            </div>

            <div id="family-responsibility-group" class="mt-5 hidden space-y-4">
              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <label for="funeral-concern-input" class="form-label">Funeral / Burial Concern</label>
                  <input
                    id="funeral-concern-input"
                    type="text"
                    placeholder="What concerns them most?"
                    class="form-input"
                  />
                </div>

                <div>
                  <label for="debts-input" class="form-label">Debts</label>
                  <input
                    id="debts-input"
                    type="text"
                    placeholder="Credit cards, loans, etc."
                    class="form-input"
                  />
                </div>

                <div>
                  <label for="household-bills-input" class="form-label">Household Bills</label>
                  <input
                    id="household-bills-input"
                    type="text"
                    placeholder="Mortgage, rent, utilities"
                    class="form-input"
                  />
                </div>

                <div>
                  <label for="dependents-input" class="form-label">Dependents</label>
                  <input
                    id="dependents-input"
                    type="text"
                    placeholder="Anyone still depending on them?"
                    class="form-input"
                  />
                </div>

                <div class="sm:col-span-2">
                  <label for="other-obligations-input" class="form-label">
                    Other Financial Obligations
                  </label>
                  <input
                    id="other-obligations-input"
                    type="text"
                    placeholder="Anything else they would not want left behind"
                    class="form-input"
                  />
                </div>
              </div>

              <div>
                <label for="family-responsibility-notes" class="form-label">Notes</label>
                <textarea
                  id="family-responsibility-notes"
                  rows="3"
                  placeholder="Capture the burden in their own words"
                  class="form-input"
                ></textarea>
              </div>
            </div>

            <div id="current-support-group" class="mt-5 hidden">
              <label for="current-support-notes" class="form-label">Notes</label>
              <textarea
                id="current-support-notes"
                rows="3"
                placeholder="What is already set aside and what they want it to handle"
                class="form-input"
              ></textarea>
            </div>

            <div id="protection-priority-group" class="mt-5 hidden space-y-4">
              <div>
                <div class="flex items-center justify-between gap-3">
                  <p class="form-label !mb-0">Impact Cards</p>
                  <p id="primary-concern-readout" class="text-xs text-gray-400">
                    No primary concern selected yet.
                  </p>
                </div>

                <div class="mt-3 grid gap-3 sm:grid-cols-2">
                  <button
                    type="button"
                    class="impact-card impact-card-idle"
                    data-impact-value="funeral costs"
                  >
                    <span class="impact-card-title">Funeral Costs</span>
                    <span class="impact-card-body">Handle the service and immediate arrangements.</span>
                  </button>

                  <button
                    type="button"
                    class="impact-card impact-card-idle"
                    data-impact-value="burial costs"
                  >
                    <span class="impact-card-title">Burial Costs</span>
                    <span class="impact-card-body">Cover cemetery, plot, and burial-related expenses.</span>
                  </button>

                  <button
                    type="button"
                    class="impact-card impact-card-idle"
                    data-impact-value="immediate household expenses"
                  >
                    <span class="impact-card-title">Immediate Household Expenses</span>
                    <span class="impact-card-body">
                      Keep the lights on and the home steady in the first few months.
                    </span>
                  </button>

                  <button
                    type="button"
                    class="impact-card impact-card-idle"
                    data-impact-value="unpaid bills"
                  >
                    <span class="impact-card-title">Unpaid Bills</span>
                    <span class="impact-card-body">Prevent card, loan, or payment pressure from piling up.</span>
                  </button>

                  <button
                    type="button"
                    class="impact-card impact-card-idle"
                    data-impact-value="easing the burden on family"
                  >

      const toolkitEmpty = visiblePanels.length === 0;

      toolkitColumn.classList.toggle("toolkit-column-empty", toolkitEmpty);
      workflowGrid.classList.toggle("workflow-grid-no-toolkit", toolkitEmpty);
    }


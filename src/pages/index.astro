  <script define:vars={{ scriptSections, rebuttals }}>
    const SETTINGS_STORAGE_KEY = "legacy_dashboard_settings_v2";
    const STATS_STORAGE_KEY = "legacy_dashboard_stats_v7";
    const SESSION_STORAGE_KEY = "legacy_dashboard_session_v5";

    function createEmptyBranchSelections() {
      return {
        coverageStatus: "",
        relationType: "",
        lossExperience: "",
        bridgeStyle: "",
        medicalReview: "",
        productOutcome: ""
      };
    }

    function todayKey() {
      const now = new Date();
      const year = now.getFullYear();
      const month = String(now.getMonth() + 1).padStart(2, "0");
      const day = String(now.getDate()).padStart(2, "0");
      return `${year}-${month}-${day}`;
    }

    function createDefaultSettings() {
      return {
        advisorName: "Nick Arias",
        advisorPhone: "YOUR_PHONE",
        advisorNPN: "YOUR_NPN",
        dailySalesGoal: 8,
        apGoal: 3000
      };
    }

    function createFreshStats() {
      return {
        date: todayKey(),
        totalCalls: 0,
        transfers: 0,
        sales: 0,
        sold: 0,
        callback: 0,
        notInterested: 0,
        medicalDQ: 0,
        apSubmitted: 0
      };
    }

    function createFreshDiscoveryData() {
      return {
        maritalStatus: "",
        spousePartner: "",
        childrenInfo: "",
        decisionMaker: "",
        primaryConcern: "",
        reliesOnThem: "",
        familyContextNotes: "",
        lossExperienceNotes: "",
        funeralConcern: "",
        debtConcerns: "",
        householdBills: "",
        dependentsConcern: "",
        otherObligations: "",
        familyResponsibilityNotes: "",
        currentSupportNotes: "",
        protectionPriorities: [],
        protectionPriorityNotes: ""
      };
    }

    function createFreshSession() {
      return {
        currentSectionId: scriptSections[0]?.id ?? 1,
        notes: "",
        outcome: "",
        clientName: "",
        clientState: "",
        beneficiaryName: "",
        premium: "",
        draftDate: "",
        medicalSummary: "",
        coverageOption1: "",
        quoteOption1: "",
        coverageOption2: "",
        quoteOption2: "",
        coverageOption3: "",
        quoteOption3: "",
        recommendedQuote: "",
        policyNumber: "",
        secondaryPhone: "",
        beneficiaryPhone: "",
        started: false,
        transferCounted: false,
        saleCounted: false,
        saleFromOutcome: false,
        countedAp: 0,
        discovery: createFreshDiscoveryData(),
        branchSelections: createEmptyBranchSelections()
      };
    }

    function loadSettings() {
      const raw = localStorage.getItem(SETTINGS_STORAGE_KEY);

      if (!raw) return createDefaultSettings();

      try {
        const parsed = JSON.parse(raw);
        return {
          advisorName: String(parsed.advisorName ?? "Nick Arias"),
          advisorPhone: String(parsed.advisorPhone ?? "YOUR_PHONE"),
          advisorNPN: String(parsed.advisorNPN ?? "YOUR_NPN"),
          dailySalesGoal: Number(parsed.dailySalesGoal ?? 8),
          apGoal: Number(parsed.apGoal ?? 3000)
        };
      } catch {
        return createDefaultSettings();
      }
    }

    function loadStats() {
      const raw = localStorage.getItem(STATS_STORAGE_KEY);

      if (!raw) return createFreshStats();

      try {
        const parsed = JSON.parse(raw);

        if (!parsed || parsed.date !== todayKey()) {
          return createFreshStats();
        }

        return {
          date: parsed.date ?? todayKey(),
          totalCalls: Number(parsed.totalCalls ?? 0),
          transfers: Number(parsed.transfers ?? 0),
          sales: Number(parsed.sales ?? 0),
          sold: Number(parsed.sold ?? 0),
          callback: Number(parsed.callback ?? 0),
          notInterested: Number(parsed.notInterested ?? 0),
          medicalDQ: Number(parsed.medicalDQ ?? 0),
          apSubmitted: Number(parsed.apSubmitted ?? 0)
        };
      } catch {
        return createFreshStats();
      }
    }

    function loadSession() {
      const raw = sessionStorage.getItem(SESSION_STORAGE_KEY);

      if (!raw) return createFreshSession();

      try {
        const parsed = JSON.parse(raw);
        const parsedBranchSelections =
          parsed.branchSelections && typeof parsed.branchSelections === "object"
            ? parsed.branchSelections
            : {};
        const parsedDiscovery =
          parsed.discovery && typeof parsed.discovery === "object" ? parsed.discovery : {};
        const decisionMaker = String(parsedDiscovery.decisionMaker ?? parsed.beneficiaryName ?? "");

        return {
          currentSectionId: Number(parsed.currentSectionId ?? (scriptSections[0]?.id ?? 1)),
          notes: String(parsed.notes ?? ""),
          outcome: String(parsed.outcome ?? ""),
          clientName: String(parsed.clientName ?? ""),
          clientState: String(parsed.clientState ?? ""),
          beneficiaryName: String(parsed.beneficiaryName ?? decisionMaker),
          premium: String(parsed.premium ?? ""),
          draftDate: String(parsed.draftDate ?? ""),
          medicalSummary: String(parsed.medicalSummary ?? ""),
          coverageOption1: String(parsed.coverageOption1 ?? ""),
          quoteOption1: String(parsed.quoteOption1 ?? ""),
          coverageOption2: String(parsed.coverageOption2 ?? ""),
          quoteOption2: String(parsed.quoteOption2 ?? ""),
          coverageOption3: String(parsed.coverageOption3 ?? ""),
          quoteOption3: String(parsed.quoteOption3 ?? ""),
          recommendedQuote: String(parsed.recommendedQuote ?? ""),
          policyNumber: String(parsed.policyNumber ?? ""),
          secondaryPhone: String(parsed.secondaryPhone ?? ""),
          beneficiaryPhone: String(parsed.beneficiaryPhone ?? ""),
          started: Boolean(parsed.started ?? false),
          transferCounted: Boolean(parsed.transferCounted ?? false),
          saleCounted: Boolean(parsed.saleCounted ?? false),
          saleFromOutcome: Boolean(parsed.saleFromOutcome ?? false),
          countedAp: Number(parsed.countedAp ?? 0),
          discovery: {
            maritalStatus: String(parsedDiscovery.maritalStatus ?? ""),
            spousePartner: String(parsedDiscovery.spousePartner ?? ""),
            childrenInfo: String(parsedDiscovery.childrenInfo ?? ""),
            decisionMaker,
            primaryConcern: String(
              parsedDiscovery.primaryConcern ??
                (Array.isArray(parsedDiscovery.protectionPriorities)
                  ? parsedDiscovery.protectionPriorities[0] ?? ""
                  : "")
            ),
            reliesOnThem: String(parsedDiscovery.reliesOnThem ?? ""),
            familyContextNotes: String(parsedDiscovery.familyContextNotes ?? ""),
            lossExperienceNotes: String(parsedDiscovery.lossExperienceNotes ?? ""),
            funeralConcern: String(parsedDiscovery.funeralConcern ?? ""),
            debtConcerns: String(parsedDiscovery.debtConcerns ?? ""),
            householdBills: String(parsedDiscovery.householdBills ?? ""),
            dependentsConcern: String(parsedDiscovery.dependentsConcern ?? ""),
            otherObligations: String(parsedDiscovery.otherObligations ?? ""),
            familyResponsibilityNotes: String(parsedDiscovery.familyResponsibilityNotes ?? ""),
            currentSupportNotes: String(parsedDiscovery.currentSupportNotes ?? ""),
            protectionPriorities: Array.isArray(parsedDiscovery.protectionPriorities)
              ? parsedDiscovery.protectionPriorities.map((value) => String(value))
              : [],
            protectionPriorityNotes: String(parsedDiscovery.protectionPriorityNotes ?? "")
          },
          branchSelections: {
            coverageStatus: String(parsedBranchSelections.coverageStatus ?? ""),
            relationType: String(parsedBranchSelections.relationType ?? parsed.relationType ?? ""),
            lossExperience: String(
              parsedBranchSelections.lossExperience ?? parsedBranchSelections.funeralExperience ?? ""
            ),
            bridgeStyle: String(parsedBranchSelections.bridgeStyle ?? ""),
            medicalReview: String(parsedBranchSelections.medicalReview ?? ""),
            productOutcome: String(parsedBranchSelections.productOutcome ?? "")
          }
        };
      } catch {
        return createFreshSession();
      }
    }

    function saveSettings() {
      localStorage.setItem(SETTINGS_STORAGE_KEY, JSON.stringify(settings));
    }

    function saveStats() {
      localStorage.setItem(STATS_STORAGE_KEY, JSON.stringify(stats));
    }

    function saveSession() {
      sessionStorage.setItem(
        SESSION_STORAGE_KEY,
        JSON.stringify({
          currentSectionId: currentSection.id,
          notes: callNotes?.value ?? "",
          outcome: sessionState.outcome,
          clientName: clientNameInput?.value ?? "",
          clientState: clientStateInput?.value ?? "",
          beneficiaryName: beneficiaryNameInput?.value ?? "",
          premium: premiumInput?.value ?? "",
          draftDate: draftDateInput?.value ?? "",
          medicalSummary: medicalSummaryInput?.value ?? "",
          coverageOption1: coverageOption1Input?.value ?? "",
          quoteOption1: quoteOption1Input?.value ?? "",
          coverageOption2: coverageOption2Input?.value ?? "",
          quoteOption2: quoteOption2Input?.value ?? "",
          coverageOption3: coverageOption3Input?.value ?? "",
          quoteOption3: quoteOption3Input?.value ?? "",
          recommendedQuote: sessionState.recommendedQuote,
          policyNumber: policyNumberInput?.value ?? "",
          secondaryPhone: secondaryPhoneInput?.value ?? "",
          beneficiaryPhone: beneficiaryPhoneInput?.value ?? "",
          started: sessionState.started,
          transferCounted: sessionState.transferCounted,
          saleCounted: sessionState.saleCounted,
          saleFromOutcome: sessionState.saleFromOutcome,
          countedAp: sessionState.countedAp,
          discovery: sessionState.discovery,
          branchSelections: sessionState.branchSelections
        })
      );
    }

    function formatCurrency(value) {
      return `$${Number(value || 0).toFixed(2)}`;
    }

    function parsePremium(value) {
      const cleaned = String(value || "").replace(/[^0-9.]/g, "");
      const parsed = Number(cleaned);
      return Number.isFinite(parsed) ? parsed : 0;
    }

    function getAnnualPremium() {
      return parsePremium(premiumInput?.value) * 12;
    }

    function formatMoneyDisplay(value, fallback = "") {
      const text = String(value || "").trim();
      if (!text) return fallback;

      const parsed = Number(text.replace(/[^0-9.]/g, ""));
      if (!Number.isFinite(parsed) || parsed <= 0) {
        return text;
      }

      return formatCurrency(parsed);
    }

    function formatCoverageDisplay(value, fallback = "") {
      const text = String(value || "").trim();
      if (!text) return fallback;

      const parsed = Number(text.replace(/[^0-9.]/g, ""));
      if (!Number.isFinite(parsed) || parsed <= 0) {
        return text;
      }

      return `$${parsed.toLocaleString("en-US", {
        minimumFractionDigits: 0,
        maximumFractionDigits: 0
      })}`;
    }

    function getClientLastName() {
      const fullName = clientNameInput?.value.trim() || "";
      if (!fullName) return "Client";

      const parts = fullName.split(/\s+/).filter(Boolean);
      return parts.at(-1) || fullName;
    }

    function getBeneficiaryRelationshipLabel() {
      const relation = getBranchSelection("relationType");

      if (relation === "spouse") return "spouse";
      if (relation === "child") return "child";
      if (relation === "sibling") return "sibling";

      return "beneficiary";
    }

    function getProductOutcomeMeta() {
      const productOutcome = getBranchSelection("productOutcome");

      if (productOutcome === "easy-life") {
        return {
          label: "EMC Easy Life",
          carrierName: "EMC National Life",
          policyLabel: "policy",
          customerExperiencePhone: "1-866-699-9099"
        };
      }

      if (productOutcome === "emc-graded") {
        return {
          label: "EMC Graded",
          carrierName: "EMC National Life",
          policyLabel: "policy",
          customerExperiencePhone: "1-866-699-9099"
        };
      }

      if (productOutcome === "eternal-legacy") {
        return {
          label: "Eternal Legacy",
          carrierName: "Monitor Life / Foresters Financial",
          policyLabel: "certificate",
          customerExperiencePhone: "1-866-699-9099"
        };
      }

      return {
        label: "No Option",
        carrierName: "Insurance Carrier",
        policyLabel: "policy",
        customerExperiencePhone: "1-866-699-9099"
      };
    }

    function getQuoteValue(optionNumber) {
      if (optionNumber === "1") return quoteOption1Input?.value.trim() || "";
      if (optionNumber === "2") return quoteOption2Input?.value.trim() || "";
      if (optionNumber === "3") return quoteOption3Input?.value.trim() || "";
      return "";
    }

    function getCoverageValue(optionNumber) {
      if (optionNumber === "1") return coverageOption1Input?.value.trim() || "";
      if (optionNumber === "2") return coverageOption2Input?.value.trim() || "";
      if (optionNumber === "3") return coverageOption3Input?.value.trim() || "";
      return "";
    }

    function getRecommendedQuoteText() {
      const recommendedQuote = sessionState.recommendedQuote || "";
      const quoteValue = getQuoteValue(recommendedQuote);
      const coverageValue = getCoverageValue(recommendedQuote);

      if (recommendedQuote && quoteValue && coverageValue) {
        return `Option ${recommendedQuote} at ${formatMoneyDisplay(
          quoteValue,
          quoteValue
        )} for ${formatCoverageDisplay(coverageValue, coverageValue)} in coverage`;
      }

      if (recommendedQuote && quoteValue) {
        return `Option ${recommendedQuote} at ${formatMoneyDisplay(quoteValue, quoteValue)}`;
      }

      if (recommendedQuote) {
        return `Option ${recommendedQuote}`;
      }

      return "The middle option";
    }

    let settings = loadSettings();
    let stats = loadStats();
    let sessionState = loadSession();

    let currentSection =
      scriptSections.find((section) => section.id === sessionState.currentSectionId) ??
      scriptSections[0];

    let timerSeconds = 0;
    let timerInterval = null;

    const sectionButtons = document.querySelectorAll(".section-button");
    const sidebarNav = document.getElementById("sidebar-nav");
    const favoriteRebuttalButtons = document.querySelectorAll(".favorite-rebuttal-button");

    const clientNameInput = document.getElementById("clientName");
    const clientStateInput = document.getElementById("clientState");
    const beneficiaryNameInput = document.getElementById("beneficiaryName");
    const premiumInput = document.getElementById("premiumInput");
    const cockpitClientNameInput = document.getElementById("cockpit-client-name");
    const cockpitPersonNameInput = document.getElementById("cockpit-person-name");
    const cockpitWhyInput = document.getElementById("cockpit-why-input");
    const cockpitStepReadout = document.getElementById("cockpit-step-readout");
    const cockpitHudPreview = document.getElementById("cockpit-hud-preview");
    const premiumEstimateDisplay = document.getElementById("premium-estimate-display");
    const premiumEstimateDetail = document.getElementById("premium-estimate-detail");
    const draftDateInput = document.getElementById("draftDateInput");
    const pricingActionPanel = document.getElementById("pricing-action-panel");
    const workflowGrid = document.getElementById("workflow-grid");
    const scriptPanel = document.getElementById("script-panel");
    const secondaryRail = document.getElementById("secondary-rail");
    const promptPanel = document.getElementById("prompt-panel");
    const quietDuringDiscoveryPanels = document.querySelectorAll("[data-quiet-during-discovery]");
    const discoveryFocusShell = document.getElementById("discovery-focus-shell");
    const discoveryPacingCue = document.getElementById("discovery-pacing-cue");
    const discoveryFocusTitle = document.getElementById("discovery-focus-title");
    const discoveryInlineNotesShell = document.getElementById("discovery-inline-notes-shell");
    const discoveryInlineNotesLabel = document.getElementById("discovery-inline-notes-label");
    const discoveryInlineNotesInput = document.getElementById("discovery-inline-notes-input");
    const discoveryWorkspacePanel = document.getElementById("discovery-workspace-panel");
    const discoveryPanelTitle = document.getElementById("discovery-panel-title");
    const discoveryPanelText = document.getElementById("discovery-panel-text");
    const primaryConcernReadout = document.getElementById("primary-concern-readout");
    const familyContextGroup = document.getElementById("family-context-group");
    const lossExperienceGroup = document.getElementById("loss-experience-group");
    const familyResponsibilityGroup = document.getElementById("family-responsibility-group");
    const currentSupportGroup = document.getElementById("current-support-group");
    const protectionPriorityGroup = document.getElementById("protection-priority-group");
    const discoveryBridgeGroup = document.getElementById("discovery-bridge-group");
    const bridgePrioritySummary = document.getElementById("bridge-priority-summary");
    const discoveryHandoffButton = document.getElementById("discovery-handoff-button");
    const maritalStatusInput = document.getElementById("marital-status-input");
    const spousePartnerInput = document.getElementById("spouse-partner-input");
    const childrenInfoInput = document.getElementById("children-info-input");
    const decisionMakerInput = document.getElementById("decision-maker-input");
    const decisionMakerRelationInput = document.getElementById("decision-maker-relation");
    const reliesOnThemInput = document.getElementById("relies-on-them-input");
    const familyContextNotesInput = document.getElementById("family-context-notes");
    const lossExperienceNotesInput = document.getElementById("loss-experience-notes");
    const funeralConcernInput = document.getElementById("funeral-concern-input");
    const debtsInput = document.getElementById("debts-input");
    const householdBillsInput = document.getElementById("household-bills-input");
    const dependentsInput = document.getElementById("dependents-input");

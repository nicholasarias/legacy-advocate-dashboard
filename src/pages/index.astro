---
import Layout from "../layouts/Layout.astro";
import TopBar from "../components/TopBar.astro";
import MetricsBar from "../components/MetricsBar.astro";
import { scriptSections } from "../data/scriptSections";
import { rebuttals } from "../data/rebuttals";

const firstSection = scriptSections[0];
const initialObjectionRebuttals = rebuttals.filter((item) => item.stageGroup === "early");
const favoriteRebuttals = initialObjectionRebuttals.filter((item) => item.favorite);
const firstSectionDisplayNumber = 1;
---

<Layout>
  <TopBar />
  <MetricsBar />

  <div id="sections-backdrop" class="fixed inset-0 z-30 hidden bg-black/55 backdrop-blur-sm"></div>

  <main class="min-h-[calc(100vh-150px)]">
    <aside
      id="sections-drawer"
      class="fixed inset-y-0 left-0 z-40 hidden w-full max-w-sm border-r border-slate-800/50 bg-slate-950/95 text-white shadow-2xl shadow-emerald-500/5"
    >
      <div class="border-b border-gray-800 px-4 py-4">
        <div class="flex items-center justify-between gap-3">
          <div>
            <h2 class="text-lg font-semibold">Script Sections</h2>
            <p class="text-xs text-gray-400">
              <span id="progress-text">1 / {scriptSections.length}</span>
            </p>
          </div>
        </div>

        <div class="mt-3 h-2 overflow-hidden rounded-full bg-gray-800">
          <div id="progress-bar" class="h-full w-[4%] bg-sky-500"></div>
        </div>
      </div>

      <nav id="sidebar-nav" class="max-h-[calc(100vh-230px)] overflow-y-auto p-2">
        <ul class="space-y-1">
          {scriptSections.map((section, index) => (
            <li>
              <button
                class:list={[
                  "section-button w-full rounded-lg px-3 py-3 text-left text-sm transition",
                  section.highlightStyle === "paint-picture" ? "section-button-highlight" : "",
                  section.id === firstSection.id ? "sidebar-button-active" : "sidebar-button-idle"
                ]}
                data-section-id={section.id}
                type="button"
              >
                <span class="block font-medium">
                  {index + 1}. {section.title}
                </span>

                {section.qaRequired && (
                  <span class="mt-1 inline-block text-xs text-amber-400">
                    Verbatim Required
                  </span>
                )}
              </button>
            </li>
          ))}
        </ul>
      </nav>
    </aside>

    <section class="dashboard-shell text-white">
      <div class="border-b border-slate-800/40 px-8 py-6">
        <div class="flex flex-col gap-4">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div class="flex flex-wrap items-center gap-3">
              <button id="toggle-sections-button" type="button" class="btn">Sections</button>
              <button id="new-call-button" type="button" class="btn-blue">New Call</button>
              <button id="outcome-sold-button" type="button" class="btn-green">Sold</button>
              <button id="toggle-objections-button" type="button" class="btn">Objections</button>

              <div
                id="qa-badge"
                class:list={[
                  "rounded-full border px-4 py-2 text-sm font-medium",
                  firstSection.qaRequired
                    ? "border-amber-500/40 bg-amber-500/10 text-amber-300"
                    : "hidden"
                ]}
              >
                Verbatim Required
              </div>
            </div>

            <button id="toggle-shortcuts-button" type="button" class="btn">Shortcuts</button>
          </div>

          <div>
            <p id="section-number" class="text-sm uppercase tracking-wide text-gray-400">
              Section {firstSectionDisplayNumber}
            </p>

            <h2 id="section-title" class="mt-1 text-3xl font-bold">
              {firstSection.title}
            </h2>
          </div>
        </div>
      </div>

      <div id="branch-toolbar-shell" class="hidden border-b border-slate-800/40 px-8 py-4">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <p id="branch-toolbar-title" class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
              Quick Path
            </p>
          </div>
          <p id="branch-toolbar-current" class="text-xs font-semibold uppercase tracking-[0.14em] text-emerald-300">
            Pick the line that fits the conversation.
          </p>
        </div>

        <div id="branch-toolbar-buttons" class="mt-3 flex flex-wrap gap-2"></div>
      </div>

      <div id="workflow-grid" class="workflow-grid-cockpit px-5 py-6 lg:px-6 xl:px-7">
        <div id="hud-column" class="space-y-6"></div>
        <div class="cockpit-flow-group space-y-6">
          <div id="branch-panel" class="panel hidden p-6">
            <div class="space-y-4">
              <div>
                <h3 id="branch-panel-title" class="panel-title !mb-2">Conversation Path</h3>
                <p id="branch-panel-text" class="text-sm text-gray-300">
                  Choose the direction that matches the conversation.
                </p>
              </div>

              <div id="branch-button-group" class="flex flex-wrap gap-3"></div>

              <div id="branch-helper-box" class="hidden rounded-xl border border-gray-800 bg-gray-950 p-4">
                <p class="text-xs uppercase tracking-wide text-gray-500">Current Direction</p>
                <div id="branch-helper-content" class="mt-3 space-y-2 text-sm text-gray-300"></div>
              </div>
            </div>
          </div>

          <div id="objections-panel" class="panel hidden p-6">
            <div class="flex items-center justify-between gap-3">
              <div>
                <h3 class="panel-title !mb-0">Objections</h3>
                <p class="mt-2 text-sm text-gray-300">
                  Relevant objections for this stage of the call, with the next line to keep the process moving.
                </p>
              </div>
              <button id="close-objections-button" type="button" class="btn">Close</button>
            </div>

            <div class="mt-5 grid gap-4 xl:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)]">
              <div>
                <p class="text-xs uppercase tracking-wide text-gray-500">Search</p>
                <input
                  id="objection-search"
                  type="text"
                  placeholder="Search objections by keyword..."
                  class="form-input mt-3"
                />
              </div>

              <div>
                <p class="text-xs uppercase tracking-wide text-gray-500">Favorites</p>
                <div id="favorite-rebuttals" class="mt-3 flex flex-wrap gap-2">
                  {favoriteRebuttals.map((item) => (
                    <button
                      type="button"
                      class="favorite-rebuttal-button rounded-full border border-gray-700 bg-gray-950 px-3 py-1 text-xs text-gray-200 hover:bg-gray-800"
                      data-rebuttal-id={item.id}
                    >
                      {item.label}
                    </button>
                  ))}
                </div>
              </div>
            </div>

            <div class="mt-5 grid gap-4 xl:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)]">
              <div>
                <p class="text-xs uppercase tracking-wide text-gray-500">Results</p>
                <div id="objection-results" class="mt-3 max-h-80 space-y-2 overflow-y-auto">
                  {initialObjectionRebuttals.slice(0, 10).map((item) => (
                    <button
                      type="button"
                      class="rebuttal-result-button block w-full rounded-lg border border-gray-800 bg-gray-950 px-3 py-2 text-left text-sm text-gray-200 hover:bg-gray-800"
                      data-rebuttal-id={item.id}
                    >
                      <div class="font-semibold">{item.label}</div>
                      <div class="mt-1 text-xs text-gray-400">{item.category}</div>
                    </button>
                  ))}
                </div>
              </div>

              <div class="rounded-xl border border-gray-800 bg-gray-950 p-4">
                <p class="text-xs uppercase tracking-wide text-gray-500">Selected Rebuttal</p>
                <div id="selected-rebuttal-title" class="mt-3 text-sm font-semibold text-white">
                  Select an objection
                </div>
                <div
                  id="selected-rebuttal-body"
                  class="mt-2 whitespace-pre-wrap text-sm leading-6 text-gray-300"
                >
                  Your selected rebuttal will appear here.
                </div>
                <div class="mt-5 border-t border-gray-800 pt-4">
                  <p class="text-xs uppercase tracking-wide text-gray-500">Move Forward</p>
                  <div
                    id="selected-rebuttal-follow-up"
                    class="mt-2 whitespace-pre-wrap text-sm font-medium leading-6 text-emerald-100"
                  >
                    The next step line will appear here.
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div id="script-panel" class="panel p-6 xl:p-7">
            <h3 class="panel-title">Read Aloud Script</h3>
            <div id="objection-trigger-bar" class="mb-5 space-y-3">
              <div class="flex flex-wrap items-center gap-2">
                <p class="text-xs uppercase tracking-wide text-gray-500">Quick Objection Triggers</p>
                <div
                  id="objection-suggestion-badge"
                  class="hidden rounded-full border border-emerald-500/25 bg-emerald-500/10 px-3 py-1 text-[11px] font-semibold text-emerald-200"
                >
                  Suggested: Think About It
                </div>
              </div>

              <div class="flex flex-wrap gap-2">
                <button type="button" class="objection-trigger-button" data-trigger-key="think-about-it">
                  Think About It
                </button>
                <button type="button" class="objection-trigger-button" data-trigger-key="price">
                  Price
                </button>
                <button type="button" class="objection-trigger-button" data-trigger-key="already-covered">
                  Already Covered
                </button>
                <button type="button" class="objection-trigger-button" data-trigger-key="spouse">
                  Spouse
                </button>
                <button type="button" class="objection-trigger-button" data-trigger-key="call-back">
                  Call Back
                </button>
                <button type="button" class="objection-trigger-button" data-trigger-key="need-to-pray">
                  Need To Pray
                </button>
                <button
                  type="button"
                  class="objection-trigger-button"
                  data-trigger-key="need-to-talk-to-family"
                >
                  Need To Talk To Family
                </button>
                <button type="button" class="objection-trigger-button" data-trigger-key="not-sure">
                  Not Sure
                </button>
                <button type="button" class="objection-trigger-button" data-trigger-key="employer-coverage">
                  Employer Coverage
                </button>
                <button type="button" class="objection-trigger-button" data-trigger-key="term-policy">
                  Term Policy
                </button>
              </div>
            </div>
            <div id="script-lines" class="space-y-5 text-xl leading-relaxed text-gray-100">
              {firstSection.script.map((line) => (
                <p>{line}</p>
              ))}
            </div>
          </div>

          <div id="pricing-action-panel" class="panel hidden p-6">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="panel-title !mb-2">Pricing Workspace</h3>
                <p class="text-sm text-gray-300">
                  Use the three-option protected-bucket comparison while you present the numbers.
                </p>
              </div>
            </div>

            <div id="quote-workspace-group" class="mt-5 space-y-3">
              <div class="grid grid-cols-1 gap-4 xl:grid-cols-2 2xl:grid-cols-3">
                <div
                  class="quote-card quote-comparison-card"
                  data-quote-card="1"
                  tabindex="0"
                  role="button"
                  aria-pressed="false"
                >
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500" data-quote-label>
                        Option 1
                      </p>
                      <h4 class="mt-2 text-lg font-semibold text-slate-100" data-quote-title>
                        The Anchor
                      </h4>
                    </div>

                    <div class="flex flex-col items-end gap-2">
                      <span data-quote-badge class="quote-badge hidden">Recommended</span>
                      <span data-quote-selected class="quote-selected hidden">Selected</span>
                    </div>
                  </div>

                  <p data-quote-summary class="mt-3 text-sm leading-6 text-slate-300">
                    Funeral, headstone, and extra breathing room.
                  </p>
                  <p
                    data-quote-bucket
                    class="mt-3 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-300"
                  >
                    Protected Bucket
                  </p>

                  <div class="mt-4 grid gap-3 sm:grid-cols-2">
                    <div>
                      <label for="coverage-option-1" class="form-label">Coverage</label>
                      <input
                        id="coverage-option-1"
                        type="text"
                        placeholder="20000"
                        class="form-input"
                      />
                    </div>

                    <div>
                      <label for="quote-option-1" class="form-label">Monthly Premium</label>
                      <input
                        id="quote-option-1"
                        type="text"
                        placeholder="82.00"
                        class="form-input"
                      />
                    </div>
                  </div>

                  <div class="quote-price-panel mt-4">
                    <p class="text-xs uppercase tracking-wide text-slate-500">Monthly Price</p>
                    <p data-quote-price-display class="mt-2 text-2xl font-semibold text-slate-100">
                      Enter premium
                    </p>
                    <p data-quote-daily-display class="mt-1 text-sm text-slate-400">
                      Daily math will appear here.
                    </p>
                  </div>
                </div>

                <div
                  class="quote-card quote-comparison-card"
                  data-quote-card="2"
                  tabindex="0"
                  role="button"
                  aria-pressed="false"
                >
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500" data-quote-label>
                        Option 2
                      </p>
                      <h4 class="mt-2 text-lg font-semibold text-slate-100" data-quote-title>
                        The Complete Solution
                      </h4>
                    </div>

                    <div class="flex flex-col items-end gap-2">
                      <span data-quote-badge class="quote-badge hidden">Recommended</span>
                      <span data-quote-selected class="quote-selected hidden">Selected</span>
                    </div>
                  </div>

                  <p data-quote-summary class="mt-3 text-sm leading-6 text-slate-300">
                    Solves the whole funding gap.
                  </p>
                  <p
                    data-quote-bucket
                    class="mt-3 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-300"
                  >
                    Protected Bucket
                  </p>

                  <div class="mt-4 grid gap-3 sm:grid-cols-2">
                    <div>
                      <label for="coverage-option-2" class="form-label">Coverage</label>
                      <input
                        id="coverage-option-2"
                        type="text"
                        placeholder="15000"
                        class="form-input"
                      />
                    </div>

                    <div>
                      <label for="quote-option-2" class="form-label">Monthly Premium</label>
                      <input
                        id="quote-option-2"
                        type="text"
                        placeholder="69.00"
                        class="form-input"
                      />
                    </div>
                  </div>

                  <div class="quote-price-panel mt-4">
                    <p class="text-xs uppercase tracking-wide text-slate-500">Monthly Price</p>
                    <p data-quote-price-display class="mt-2 text-2xl font-semibold text-slate-100">
                      Enter premium
                    </p>
                    <p data-quote-daily-display class="mt-1 text-sm text-slate-400">
                      Daily math will appear here.
                    </p>
                  </div>
                </div>

                <div
                  class="quote-card quote-comparison-card"
                  data-quote-card="3"
                  tabindex="0"
                  role="button"
                  aria-pressed="false"
                >
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500" data-quote-label>
                        Option 3
                      </p>
                      <h4 class="mt-2 text-lg font-semibold text-slate-100" data-quote-title>
                        The Safety Net
                      </h4>
                    </div>

                    <div class="flex flex-col items-end gap-2">
                      <span data-quote-badge class="quote-badge hidden">Recommended</span>
                      <span data-quote-selected class="quote-selected hidden">Selected</span>
                    </div>
                  </div>

                  <p data-quote-summary class="mt-3 text-sm leading-6 text-slate-300">
                    Basic funeral home costs.
                  </p>
                  <p
                    data-quote-bucket
                    class="mt-3 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-300"
                  >
                    Protected Bucket
                  </p>

                  <div class="mt-4 grid gap-3 sm:grid-cols-2">
                    <div>
                      <label for="coverage-option-3" class="form-label">Coverage</label>
                      <input
                        id="coverage-option-3"
                        type="text"
                        placeholder="10000"
                        class="form-input"
                      />
                    </div>

                    <div>
                      <label for="quote-option-3" class="form-label">Monthly Premium</label>
                      <input
                        id="quote-option-3"
                        type="text"
                        placeholder="55.00"
                        class="form-input"
                      />
                    </div>
                  </div>

                  <div class="quote-price-panel mt-4">
                    <p class="text-xs uppercase tracking-wide text-slate-500">Monthly Price</p>
                    <p data-quote-price-display class="mt-2 text-2xl font-semibold text-slate-100">
                      Enter premium
                    </p>
                    <p data-quote-daily-display class="mt-1 text-sm text-slate-400">
                      Daily math will appear here.
                    </p>
                  </div>
                </div>
              </div>

              <div class="rounded-xl border border-gray-800 bg-gray-950 p-4">
                <p class="text-xs uppercase tracking-wide text-gray-500">Comparison Snapshot</p>
                <p id="recommended-quote-display" class="mt-2 text-sm text-gray-200">
                  Most people I work with go with Option 2 because it solves the whole problem without breaking the bank.
                </p>
              </div>
            </div>

            <div id="pricing-objections-group" class="mt-5">
              <p class="text-xs uppercase tracking-wide text-gray-500">Quick Objections</p>
              <div class="mt-3 flex flex-wrap gap-2">
                <button type="button" class="quick-objection-button" data-rebuttal-id="201">
                  Can't Afford It
                </button>
                <button type="button" class="quick-objection-button" data-rebuttal-id="203">
                  Need To Think
                </button>
                <button type="button" class="quick-objection-button" data-rebuttal-id="204">
                  Talk To Spouse
                </button>
                <button type="button" class="quick-objection-button" data-rebuttal-id="211">
                  Has Savings
                </button>
                <button type="button" class="quick-objection-button" data-rebuttal-id="212">
                  Family Will Pay
                </button>
                <button type="button" class="quick-objection-button" data-rebuttal-id="207">
                  Call Back Later
                </button>
              </div>
            </div>

            <div id="pricing-objections-panel-host" class="hidden mt-5"></div>

          </div>
        </div>

        <div id="secondary-rail" class="cockpit-flow-group self-start space-y-6">
          <div id="advisor-capture-panel" class="panel cockpit-glass-panel p-6">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <h3 class="panel-title !mb-2">Discovery Intake</h3>
                <p class="text-sm text-gray-300">
                  Keep the person, the main concern, and the current step in one place.
                </p>
              </div>

              <div class="rounded-full border border-emerald-500/25 bg-emerald-500/10 px-3 py-1 text-xs font-semibold text-emerald-300">
                <span id="cockpit-step-readout">Section 1 of {scriptSections.length}</span>
              </div>
            </div>

            <div class="mt-5 grid gap-4">
              <div class="grid gap-4 xl:grid-cols-2">
                <div>
                  <label for="cockpit-client-name" class="form-label">Client Name</label>
                  <input
                    id="cockpit-client-name"
                    type="text"
                    placeholder="Client name"
                    class="form-input cockpit-input"
                  />
                </div>

                <div>
                  <label for="cockpit-person-name" class="form-label">Person Who Matters Most</label>
                  <input
                    id="cockpit-person-name"
                    type="text"
                    placeholder="Who are we protecting?"
                    class="form-input cockpit-input"
                  />
                </div>
              </div>

              <div>
                <label for="cockpit-why-input" class="form-label">Primary Concern</label>
                <textarea
                  id="cockpit-why-input"
                  rows="3"
                  placeholder="What would be hardest for them to carry in those first few months?"
                  class="form-input cockpit-input"
                ></textarea>
              </div>

              <div class="cockpit-preview-card rounded-2xl border border-emerald-500/15 bg-emerald-500/5 p-4">
                <p class="text-xs uppercase tracking-wide text-emerald-300">HUD Preview</p>
                <p id="cockpit-hud-preview" class="mt-2 text-sm leading-6 text-emerald-50">
                  What would this mean for the person they care about most?
                </p>
              </div>
            </div>
          </div>

          <div id="prompt-panel" class="panel p-5" data-quiet-during-discovery="true">
            <div>
              <h3 class="panel-title !mb-2">Quick Notes</h3>
              <p class="text-sm text-gray-300">
                Keep the main concern and your running notes close while you move through the call.
              </p>
            </div>

            <div class="mt-4 space-y-4">
              <div class="rounded-xl border border-emerald-500/15 bg-emerald-500/6 p-4">
                <p class="text-xs uppercase tracking-wide text-emerald-300">Primary Concern</p>
                <p id="reference-why-readout" class="mt-2 text-sm leading-6 text-emerald-50">
                  Capture the main concern and it will stay here for the rest of the call.
                </p>
              </div>

              <div>
                <label for="family-context-notes" class="form-label">Call Notes</label>
                <textarea
                  id="family-context-notes"
                  rows="4"
                  placeholder="Keep the running details you want to reference later in the call"
                  class="form-input"
                ></textarea>
              </div>
            </div>
          </div>

          <div id="discovery-workspace-panel" class="panel hidden p-6" data-quiet-during-discovery="true">
            <div>
              <h3 id="discovery-panel-title" class="panel-title !mb-2">Discovery Workspace</h3>
              <p id="discovery-panel-text" class="text-sm text-gray-300">
                Capture family priorities and notes while you listen.
              </p>
            </div>

            <div class="mt-4 rounded-xl border border-sky-500/20 bg-sky-950/20 p-4">
              <p class="text-xs uppercase tracking-wide text-sky-200">Visual Cue</p>
              <p class="mt-2 text-sm text-sky-50">
                PAUSE: Let them answer and sit in the silence.
              </p>
            </div>

            <div id="family-context-group" class="mt-5 hidden space-y-4">
              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <label for="marital-status-input" class="form-label">Marital Status</label>
                  <select id="marital-status-input" class="form-input">
                    <option value="">Select status</option>
                    <option value="married">Married</option>
                    <option value="partnered">Partnered</option>
                    <option value="single">Single</option>
                    <option value="widowed">Widowed</option>
                    <option value="divorced">Divorced</option>
                    <option value="other">Other</option>
                  </select>
                </div>

                <div>
                  <label for="spouse-partner-input" class="form-label">Spouse / Partner</label>
                  <input
                    id="spouse-partner-input"
                    type="text"
                    placeholder="Name or quick note"
                    class="form-input"
                  />
                </div>

                <div>
                  <label for="children-info-input" class="form-label">Children</label>
                  <input
                    id="children-info-input"
                    type="text"
                    placeholder="How many or nearby?"
                    class="form-input"
                  />
                </div>

                <div>
                  <label for="decision-maker-input" class="form-label">Likely Decision Maker</label>
                  <input
                    id="decision-maker-input"
                    type="text"
                    placeholder="Who would handle things?"
                    class="form-input"
                  />
                </div>

                <div>
                  <label for="decision-maker-relation" class="form-label">
                    Decision Maker Relationship
                  </label>
                  <select id="decision-maker-relation" class="form-input">
                    <option value="">Select relationship</option>
                    <option value="spouse">Spouse / Partner</option>
                    <option value="child">Child</option>

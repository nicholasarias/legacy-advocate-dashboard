        updateToolkitVisibility();
        return;
      }

      salesWorkspacePanel.classList.remove("hidden");

      const summaryParts = [];

      if (medicalReview === "medical-history") {
        summaryParts.push("Medical review: history exists");
      } else if (medicalReview === "no-history") {
        summaryParts.push("Medical review: no issues");
      }

      if (productOutcome) {
        summaryParts.push(`Product route: ${productMeta.label}`);
      } else if (sectionId >= 15) {
        summaryParts.push("Product route: select a route in Product Path");
      }

      if (premiumInput?.value.trim()) {
        summaryParts.push(`Current premium: ${formatMoneyDisplay(premiumInput.value, premiumInput.value)}`);
      }

      if (draftDateInput?.value.trim()) {
        summaryParts.push(`Draft day: ${draftDateInput.value}`);
      }

      salesRouteSummary.textContent =
        summaryParts.join(" | ") ||
        "Medical notes, route details, and enrollment fields will appear here when they apply.";

      const showMedicalSummary = sectionId >= 13 && sectionId <= 19;
      const showEnrollment = sectionId >= 22 && sectionId <= 23 && productOutcome !== "no-option";

      medicalSummaryGroup.classList.toggle("hidden", !showMedicalSummary);
      enrollmentWorkspaceGroup.classList.toggle("hidden", !showEnrollment);
      updateToolkitVisibility();
    }

    function updatePricingActionPanel(section) {
      if (!pricingActionPanel || !quoteWorkspaceGroup || !pricingObjectionsGroup) {
        return;
      }

      const productOutcome = getBranchSelection("productOutcome");
      const sectionId = section.id;
      const showPanel = sectionId === 20 && productOutcome !== "no-option";

      pricingActionPanel.classList.toggle("hidden", !showPanel);
      quoteWorkspaceGroup.classList.toggle("hidden", !showPanel);
      pricingObjectionsGroup.classList.toggle("hidden", !showPanel);

      updateRecommendedQuoteUI();
      updateObjectionsPlacement(section);
      updateToolkitVisibility();
    }

    function setBranchSelection(stateKey, value) {
      sessionState.branchSelections = {
        ...sessionState.branchSelections,
        [stateKey]: value
      };

      pendingBranchHighlight = {
        stateKey,
        value
      };

      if (stateKey === "productOutcome" && currentSection.id === 15) {
        const nextSection =
          scriptSections.find((section) => section.id === getProductRouteStartSectionId(value)) ||
          currentSection;
        renderSection(nextSection);
        return;
      }

      renderSection(currentSection);
    }

    function getScriptLines(item) {
      return Array.isArray(item?.script) ? item.script : [];
    }

    function getRenderableScriptBlocks(section) {
      const tokens = getTokens();
      const branch = getBranchConfig(section);
      const selectedOption = getSelectedBranchOption(section);
      const replaceBase = Boolean(branch?.replaceBaseOnSelect && selectedOption);
      const blocks = [];

      if (!replaceBase) {
        blocks.push({
          type: "base",
          lines: getScriptLines(section).map((line) => applyTokens(line, tokens))
        });
      }

      const selectedOptionLines = getScriptLines(selectedOption);
      const selectedOptionLevels = Array.isArray(selectedOption?.levels)
        ? selectedOption.levels
            .map((level) => ({
              label: level.label || "Level",
              lines: Array.isArray(level.lines)
                ? level.lines.map((line) => applyTokens(line, tokens))
                : []
            }))
            .filter((level) => level.lines.length)
        : [];
      const selectedOptionReinforcement = Array.isArray(selectedOption?.reinforcementLines)
        ? selectedOption.reinforcementLines.map((line) => applyTokens(line, tokens))
        : [];

      if (selectedOptionLines.length || selectedOptionLevels.length) {
        blocks.push({
          type: "branch",
          heading: `${branch?.label || "Selected Path"}: ${selectedOption.label}`,
          lines: selectedOptionLines.map((line) => applyTokens(line, tokens)),
          levels: selectedOptionLevels,
          status: selectedOption?.status || "",
          emphasize:
            pendingBranchHighlight?.stateKey === branch?.stateKey &&
            pendingBranchHighlight?.value === selectedOption.value
        });
      }

      if (selectedOptionReinforcement.length) {
        blocks.push({
          type: "quick-insert",
          heading: "Quick Insert",
          lines: selectedOptionReinforcement
        });
      }

      return blocks;
    }

    function renderBranchPanel(section) {
      if (
        !branchToolbarShell ||
        !branchToolbarTitle ||
        !branchToolbarCurrent ||
        !branchToolbarButtons
      ) {
        return;
      }

      const branch = getBranchConfig(section);

      if (!branch || branch.display === false) {
        branchToolbarShell.classList.add("hidden");
        branchToolbarButtons.innerHTML = "";
        return;
      }

      branchToolbarShell.classList.remove("hidden");
      branchToolbarTitle.textContent = branch.label || "Quick Path";
      branchToolbarButtons.innerHTML = "";

      branch.options.forEach((option) => {
        const isActive = option.value === getBranchSelection(branch.stateKey);
        const button = document.createElement("button");
        button.type = "button";
        button.className = `branch-toolbar-button ${isActive ? "branch-toolbar-button-active" : "branch-toolbar-button-idle"}`;
        button.textContent = option.label;
        button.addEventListener("click", () => setBranchSelection(branch.stateKey, option.value));
        branchToolbarButtons.appendChild(button);
      });

      const selectedOption = getSelectedBranchOption(section);

      if (!selectedOption) {
        branchToolbarCurrent.textContent = "Pick the line that fits the conversation.";
        return;
      }

      branchToolbarCurrent.textContent = `Current: ${selectedOption.label}`;
    }

    function renderSupportPanel(section) {
      if (
        !branchPanel ||
        !branchPanelTitle ||
        !branchPanelText ||
        !branchButtonGroup ||
        !branchHelperBox ||
        !branchHelperContent
      ) {
        return;
      }

      const discoveryActive = isDiscoverySection(section);
      const branch = getBranchConfig(section);
      const selectedOption = getSelectedBranchOption(section);
      const supportGroups = [];

      if (branch?.helpText) {
        supportGroups.push({
          label: selectedOption ? `Current Path: ${selectedOption.label}` : "Branch Guidance",
          lines: [selectedOption?.description || branch.helpText]
        });
      }

      if (selectedOption?.helperLines?.length) {
        supportGroups.push({
          label: "Path Notes",
          lines: selectedOption.helperLines
        });
      }

      if (selectedOption?.promptNotes?.length) {
        supportGroups.push({
          label: "Delivery Notes",
          lines: selectedOption.promptNotes
        });
      }

      if (section.helperLines?.length) {
        supportGroups.push({
          label: "Bridge Notes",
          lines: section.helperLines
        });
      }

      if (section.prompt?.notes?.length) {
        supportGroups.push({
          label: "Advisor Notes",
          lines: section.prompt.notes
        });
      }

      const showPanel = discoveryActive && (section.prompt?.goal || supportGroups.length);

      branchPanel.classList.toggle("hidden", !showPanel);

      if (!showPanel) {
        branchButtonGroup.innerHTML = "";
        branchButtonGroup.classList.add("hidden");
        branchHelperBox.classList.add("hidden");
        branchHelperContent.innerHTML = "";
        return;
      }

      branchPanelTitle.textContent = "Call Support";
      branchPanelText.textContent =
        section.prompt?.goal || "Use the support notes below to guide the conversation.";
      branchButtonGroup.innerHTML = "";
      branchButtonGroup.classList.add("hidden");
      branchHelperContent.innerHTML = "";

      if (!supportGroups.length) {
        branchHelperBox.classList.add("hidden");
        return;
      }

      branchHelperBox.classList.remove("hidden");

      supportGroups.forEach((group) => {
        const wrapper = document.createElement("div");
        wrapper.className = "space-y-2 rounded-xl border border-slate-800/70 bg-slate-950/60 p-3";

        const label = document.createElement("p");
        label.className = "text-xs font-semibold uppercase tracking-[0.14em] text-slate-500";
        label.textContent = group.label;
        wrapper.appendChild(label);

        group.lines.forEach((line) => {
          const lineEl = document.createElement("p");
          lineEl.className = "text-sm leading-6 text-slate-300";
          lineEl.textContent = line;
          wrapper.appendChild(lineEl);
        });

        branchHelperContent.appendChild(wrapper);
      });
    }

    function keepActiveSidebarItemVisible() {
      const activeButton = document.querySelector(".section-button.sidebar-button-active");
      if (!activeButton || !sidebarNav) return;

      activeButton.scrollIntoView({
        behavior: "smooth",
        block: "nearest"
      });
    }

    function renderSection(section) {
      const previousSectionId = currentSection?.id;
      currentSection = section;

      if (sectionNumber) sectionNumber.textContent = `Section ${getSectionDisplayNumber(section)}`;
      if (sectionTitle) sectionTitle.textContent = section.title;

      if (qaBadge) {
        if (section.qaRequired) {
          qaBadge.classList.remove("hidden");
        } else {
          qaBadge.classList.add("hidden");
        }
      }

      if (scriptLines) {
        scriptLines.innerHTML = "";

        getRenderableScriptBlocks(section).forEach((block) => {
          const blockEl = document.createElement("div");
          blockEl.className =
            block.type === "branch"
              ? `script-block script-branch-block${block.emphasize ? " script-branch-block-flash" : ""}`
              : block.type === "quick-insert"
                ? "script-block script-branch-block script-quick-insert-block"
              : "script-block script-base-block";

          if ((block.type === "branch" || block.type === "quick-insert") && block.heading) {
            const label = document.createElement("div");
            label.className = "script-branch-label";
            label.textContent = block.heading;

             if (block.status) {
              const status = document.createElement("span");
              status.className = "script-branch-status";
              status.textContent = block.status;
              label.appendChild(status);
            }

            blockEl.appendChild(label);
          }

          block.lines.forEach((line) => {
            const p = document.createElement("p");
            p.className = "script-line";
            p.innerHTML = formatScriptLine(line);
            blockEl.appendChild(p);
          });

          if (Array.isArray(block.levels) && block.levels.length) {
            block.levels.forEach((level) => {
              const details = document.createElement("details");
              details.className = "close-response-level";
              details.open = true;

              const summary = document.createElement("summary");
              summary.textContent = level.label;
              details.appendChild(summary);

              const content = document.createElement("div");
              content.className = "close-response-level-content";

              level.lines.forEach((line) => {
                const p = document.createElement("p");
                p.className = "script-line";
                p.innerHTML = formatScriptLine(line);
                content.appendChild(p);
              });

              details.appendChild(content);
              blockEl.appendChild(details);
            });
          }

          scriptLines.appendChild(blockEl);
        });
      }

      pendingBranchHighlight = null;

      sectionButtons.forEach((button) => {
        const isActive = Number(button.dataset.sectionId) === section.id;

        button.classList.remove("sidebar-button-active", "sidebar-button-idle");

        if (isActive) {
          button.classList.add("sidebar-button-active");
        } else {
          button.classList.add("sidebar-button-idle");
        }
      });

      renderBranchPanel(section);
      renderSupportPanel(section);
      updateAdvisorCockpit(section);
      updateReferencePanel(section);
      updateDiscoveryFocusCard(section);
      updateDiscoveryWorkspace(section);
      updateSalesWorkspace(section);
      updatePricingActionPanel(section);
      if (previousSectionId && previousSectionId !== section.id) {
        secondaryRail?.scrollTo({
          top: 0,
          behavior: "smooth"
        });
      }
      if (
        objectionSearch &&
        getObjectionStageGroup({ id: previousSectionId }) !== getObjectionStageGroup(section)
      ) {
        objectionSearch.value = "";
      }
      refreshRebuttalCollections();
      refreshObjectionTriggerSuggestion();
      selectRebuttal(activeRebuttalId);
      updateProgress();
      keepActiveSidebarItemVisible();
      saveSession();
    }

    function goToAdjacentSection(direction) {
      const currentIndex = scriptSections.findIndex((section) => section.id === currentSection.id);
      if (currentIndex === -1) return;

      let nextIndex = currentIndex + direction;

      while (nextIndex >= 0 && nextIndex < scriptSections.length) {
        const nextSection = scriptSections[nextIndex];

        if (isSectionRelevantForRoute(nextSection)) {
          renderSection(nextSection);
          return;
        }

        nextIndex += direction;
      }

      return;
    }


      const currentStageGroup = getObjectionStageGroup();
      const rebuttalId = definition?.rebuttalIds?.[currentStageGroup];
      const resultQuery = definition?.resultQueries?.[currentStageGroup] || "";

      if (!definition || !rebuttalId) return;

      activeObjectionTriggerKey = triggerKey;
      showObjectionsPanel(false);

      if (objectionSearch) {

        if (!(button instanceof HTMLElement)) return;

        const triggerKey = button.dataset.triggerKey || "";
        const isActive = triggerKey === activeObjectionTriggerKey;
        const isSuggested = triggerKey === suggestedObjectionTriggerKey && !isActive;

        button.classList.toggle("objection-trigger-button-active", isActive);
        button.classList.toggle("objection-trigger-button-suggested", isSuggested);
        button.setAttribute("aria-pressed", String(isActive));

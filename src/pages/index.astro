        advisorNPN: settingsAdvisorNpn?.value.trim() || "YOUR_NPN",
        dailySalesGoal: Number(settingsSalesGoal?.value || 8),
        apGoal: Number(settingsApGoal?.value || 3000)
      };

      saveSettings();
      updateSettingsUI();
      renderSection(currentSection);
      closeSettings();

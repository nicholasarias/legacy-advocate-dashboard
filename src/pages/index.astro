      if (source !== "beneficiary" && beneficiaryNameInput && beneficiaryNameInput.value !== nextValue) {
        beneficiaryNameInput.value = nextValue;
      }
    }

    function getTokens() {
      const productMeta = getProductOutcomeMeta();

      return {
        ClientName: clientNameInput?.value.trim() || "Client Name",
        ClientLastName: getClientLastName(),
        ClientState: clientStateInput?.value.trim().toUpperCase() || "Client State",
        BeneficiaryName: getAdvisorFocusName(),
        BeneficiaryRelationship: getBeneficiaryRelationshipLabel(),
        PrimaryConcern: getPrimaryConcern(),
        PrioritySummary: getPrioritySummary(),
        AdvisorName: settings.advisorName || "Advisor Name",
        AdvisorPhone: settings.advisorPhone || "Advisor Phone",
        AdvisorNPN: settings.advisorNPN || "Advisor NPN",
        Premium: premiumInput?.value.trim() || "Premium",
        DraftDate: draftDateInput?.value.trim() || "Draft Date",
        MedicalSummary: medicalSummaryInput?.value.trim() || "that medical history",
        Coverage1: formatCoverageDisplay(coverageOption1Input?.value, "___"),
        Quote1: formatMoneyDisplay(quoteOption1Input?.value, "___"),
        Coverage2: formatCoverageDisplay(coverageOption2Input?.value, "___"),
        Quote2: formatMoneyDisplay(quoteOption2Input?.value, "___"),
        Coverage3: formatCoverageDisplay(coverageOption3Input?.value, "___"),
        Quote3: formatMoneyDisplay(quoteOption3Input?.value, "___"),
        RecommendedQuote: getRecommendedQuoteText(),
        CarrierName: productMeta.carrierName,
        PolicyLabel: productMeta.policyLabel,
        PolicyNumber: policyNumberInput?.value.trim() || "Policy Number",
        CustomerExperiencePhone: productMeta.customerExperiencePhone
      };
    }

    function applyTokens(text, tokens) {
      return text.replace(/\[([A-Za-z0-9]+)\]/g, (match, key) => tokens[key] ?? match);
    }

    function formatScriptLine(text) {
      const escaped = String(text || "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/\"/g, "&quot;")
        .replace(/'/g, "&#39;");

      return escaped
        .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
        .replace(/\*(.+?)\*/g, "<em>$1</em>");
    }

    function updateProgress() {
      const total = scriptSections.length;
      const currentIndex = scriptSections.findIndex((item) => item.id === currentSection.id);
      const current = currentIndex + 1;
      const percent = Math.max(4, (current / total) * 100);

      if (progressText) progressText.textContent = `${current} / ${total}`;
      if (progressBar) progressBar.style.width = `${percent}%`;
    }

    function getBranchConfig(section) {
      return section.branchControl || null;
    }

    function getBranchSelection(stateKey) {
      return sessionState.branchSelections?.[stateKey] || "";
    }

    function getProductRouteStartSectionId(productOutcome) {
      if (productOutcome === "easy-life" || productOutcome === "emc-graded") {
        return 16;
      }

      if (productOutcome === "eternal-legacy") {
        return 17;
      }

      if (productOutcome === "no-option") {
        return 17;
      }

      return currentSection.id;
    }

    function isSectionRelevantForRoute(section) {
      const productOutcome = getBranchSelection("productOutcome");

      if (!productOutcome) return true;

      if (productOutcome === "easy-life" || productOutcome === "emc-graded") {
        return section.id !== 18;
      }

      if (productOutcome === "eternal-legacy") {
        return section.id !== 16;
      }

      if (productOutcome === "no-option") {
        return ![16, 18, 20, 21, 22].includes(section.id);
      }

      return true;
    }

    function getSelectedBranchOption(section) {
      const branch = getBranchConfig(section);
      if (!branch) return null;

      return branch.options.find((option) => option.value === getBranchSelection(branch.stateKey)) || null;
    }

    function updateRecommendedQuoteUI() {
      const recommendedQuote = sessionState.recommendedQuote || "";

      quoteCards.forEach((card) => {
        const isActive = card instanceof HTMLElement && card.dataset.quoteCard === recommendedQuote;
        card.classList.toggle("quote-card-active", isActive);
      });

      recommendQuoteButtons.forEach((button) => {
        if (!(button instanceof HTMLElement)) return;

        const isActive = button.dataset.recommendQuote === recommendedQuote;
        button.classList.toggle("quote-chip-active", isActive);
        button.classList.toggle("quote-chip-idle", !isActive);
        button.textContent = isActive ? "Recommended" : "Recommend";
      });

      if (recommendedQuoteDisplay) {
        recommendedQuoteDisplay.textContent = recommendedQuote
          ? `${getRecommendedQuoteText()} is marked as the preferred quote.`
          : "No recommendation selected yet.";
      }
    }

    function updateSalesWorkspace(section) {
      if (
        !salesWorkspacePanel ||
        !salesRouteSummary ||
        !medicalSummaryGroup ||
        !enrollmentWorkspaceGroup
      ) {
        return;
      }

      const productOutcome = getBranchSelection("productOutcome");
      const medicalReview = getBranchSelection("medicalReview");
      const productMeta = getProductOutcomeMeta();
      const sectionId = section.id;
      const showWorkspace = sectionId >= 13 && sectionId <= 23;

      if (!showWorkspace) {
        salesWorkspacePanel.classList.add("hidden");
        medicalSummaryGroup.classList.add("hidden");
        enrollmentWorkspaceGroup.classList.add("hidden");
        return;
      }

      salesWorkspacePanel.classList.remove("hidden");

      const summaryParts = [];

      if (medicalReview === "medical-history") {
        summaryParts.push("Medical review: history exists");
      } else if (medicalReview === "no-history") {
        summaryParts.push("Medical review: no issues");
      }

      if (productOutcome) {
        summaryParts.push(`Product route: ${productMeta.label}`);
      } else if (sectionId >= 15) {
        summaryParts.push("Product route: select a route in section 15");
      }

      if (premiumInput?.value.trim()) {
        summaryParts.push(`Current premium: ${formatMoneyDisplay(premiumInput.value, premiumInput.value)}`);
      }

      if (draftDateInput?.value.trim()) {
        summaryParts.push(`Draft day: ${draftDateInput.value}`);
      }

      salesRouteSummary.textContent =
        summaryParts.join(" | ") ||
        "Medical notes, route details, and enrollment fields will appear here when they apply.";

      const showMedicalSummary = sectionId >= 13 && sectionId <= 19;
      const showEnrollment = sectionId >= 22 && sectionId <= 23 && productOutcome !== "no-option";

      medicalSummaryGroup.classList.toggle("hidden", !showMedicalSummary);
      enrollmentWorkspaceGroup.classList.toggle("hidden", !showEnrollment);
    }

    function updatePricingActionPanel(section) {
      if (!pricingActionPanel || !quoteWorkspaceGroup || !pricingObjectionsGroup) {
        return;
      }

      const productOutcome = getBranchSelection("productOutcome");
      const sectionId = section.id;
      const showPanel = sectionId === 20 && productOutcome !== "no-option";

      pricingActionPanel.classList.toggle("hidden", !showPanel);
      quoteWorkspaceGroup.classList.toggle("hidden", !showPanel);
      pricingObjectionsGroup.classList.toggle("hidden", !showPanel);

      updateRecommendedQuoteUI();
    }

    function getPromptNotesList(section) {
      const selectedOption = getSelectedBranchOption(section);

      return [...(section.prompt?.notes || []), ...(selectedOption?.promptNotes || [])];
    }

    function updatePromptNotes(section) {
      if (!promptNotes) return;

      promptNotes.innerHTML = "";

      const notes = getPromptNotesList(section);

      if (!notes.length) {
        const p = document.createElement("p");
        p.textContent = "No prompt notes for this section.";
        promptNotes.appendChild(p);
        return;
      }

      notes.forEach((note) => {
        const p = document.createElement("p");
        p.textContent = `- ${note}`;
        promptNotes.appendChild(p);
      });
    }

    function setBranchSelection(stateKey, value) {
      sessionState.branchSelections = {
        ...sessionState.branchSelections,
        [stateKey]: value
      };

      pendingBranchHighlight = {
        stateKey,
        value
      };

      if (stateKey === "productOutcome" && currentSection.id === 15) {
        const nextSection =
          scriptSections.find((section) => section.id === getProductRouteStartSectionId(value)) ||
          currentSection;
        renderSection(nextSection);
        return;
      }

      renderSection(currentSection);
    }

    function getRenderableScriptBlocks(section) {
      const tokens = getTokens();
      const branch = getBranchConfig(section);
      const selectedOption = getSelectedBranchOption(section);
      const replaceBase = Boolean(branch?.replaceBaseOnSelect && selectedOption);
      const blocks = [];

      if (!replaceBase) {
        blocks.push({
          type: "base",
          lines: (section.script || []).map((line) => applyTokens(line, tokens))
        });
      }

      if (selectedOption?.script?.length) {
        blocks.push({
          type: "branch",
          heading: `${branch?.label || "Selected Path"}: ${selectedOption.label}`,
          lines: selectedOption.script.map((line) => applyTokens(line, tokens)),
          emphasize:
            pendingBranchHighlight?.stateKey === branch?.stateKey &&
            pendingBranchHighlight?.value === selectedOption.value
        });
      }

      return blocks;
    }

    function renderBranchPanel(section) {
      if (
        !branchPanel ||
        !branchPanelTitle ||
        !branchPanelText ||
        !branchButtonGroup ||
        !branchHelperBox ||
        !branchHelperContent
      ) {
        return;
      }

      const branch = getBranchConfig(section);

      if (!branch || branch.display === false) {
        branchPanel.classList.add("hidden");
        branchButtonGroup.innerHTML = "";
        branchHelperContent.innerHTML = "";
        branchHelperBox.classList.add("hidden");
        return;
      }

      branchPanel.classList.remove("hidden");
      branchPanelTitle.textContent = branch.label || "Conversation Path";
      branchPanelText.textContent =
        branch.helpText || "Choose the direction that matches the conversation.";

      branchButtonGroup.innerHTML = "";

      branch.options.forEach((option) => {
        const isActive = option.value === getBranchSelection(branch.stateKey);
        const button = document.createElement("button");
        button.type = "button";
        button.className = `branch-button ${isActive ? "branch-button-active" : "branch-button-idle"}`;

        const label = document.createElement("span");
        label.className = "block text-sm font-semibold text-white";
        label.textContent = option.label;

        const description = document.createElement("span");
        description.className = "mt-1 block text-xs text-gray-300";
        description.textContent = option.description;

        button.appendChild(label);
        button.appendChild(description);
        button.addEventListener("click", () => setBranchSelection(branch.stateKey, option.value));

        branchButtonGroup.appendChild(button);
      });

      const selectedOption = getSelectedBranchOption(section);

      if (!selectedOption) {
        branchHelperBox.classList.add("hidden");
        branchHelperContent.innerHTML = "";
        return;
      }

      branchHelperBox.classList.remove("hidden");
      branchHelperContent.innerHTML = "";

      const description = document.createElement("p");
      description.textContent = applyTokens(selectedOption.description || "", getTokens());
      branchHelperContent.appendChild(description);

      (selectedOption.helperLines || []).forEach((line) => {
        const p = document.createElement("p");
        p.textContent = `- ${applyTokens(line, getTokens())}`;
        branchHelperContent.appendChild(p);
      });
    }

    function keepActiveSidebarItemVisible() {
      const activeButton = document.querySelector(".section-button.sidebar-button-active");
      if (!activeButton || !sidebarNav) return;

      activeButton.scrollIntoView({
        behavior: "smooth",
        block: "nearest"
      });
    }

    function renderSection(section) {
      currentSection = section;

      if (sectionNumber) sectionNumber.textContent = `Section ${section.id}`;
      if (sectionTitle) sectionTitle.textContent = section.title;
      if (promptGoal) promptGoal.textContent = section.prompt.goal;

      if (qaBadge) {
        if (section.qaRequired) {
          qaBadge.classList.remove("hidden");
        } else {
          qaBadge.classList.add("hidden");
        }
      }

      if (scriptLines) {
        scriptLines.innerHTML = "";

        getRenderableScriptBlocks(section).forEach((block) => {
          const blockEl = document.createElement("div");
          blockEl.className =
            block.type === "branch"
              ? `script-block script-branch-block${block.emphasize ? " script-branch-block-flash" : ""}`
              : "script-block script-base-block";

          if (block.type === "branch" && block.heading) {
            const label = document.createElement("div");
            label.className = "script-branch-label";
            label.textContent = block.heading;
            blockEl.appendChild(label);
          }

          block.lines.forEach((line) => {
            const p = document.createElement("p");
            p.className = "script-line";
            p.innerHTML = formatScriptLine(line);
            blockEl.appendChild(p);
          });

          scriptLines.appendChild(blockEl);
        });
      }

      pendingBranchHighlight = null;

      sectionButtons.forEach((button) => {
        const isActive = Number(button.dataset.sectionId) === section.id;

        button.classList.remove("sidebar-button-active", "sidebar-button-idle");

        if (isActive) {
          button.classList.add("sidebar-button-active");
        } else {
          button.classList.add("sidebar-button-idle");
        }
      });

      updatePromptNotes(section);
      renderBranchPanel(section);
      updateAdvisorCockpit(section);
      updateDiscoveryFocusCard(section);
      updateDiscoveryWorkspace(section);
      updateSalesWorkspace(section);
      updatePricingActionPanel(section);
      selectRebuttal(activeRebuttalId);
      updateProgress();
      keepActiveSidebarItemVisible();
      saveSession();
    }

    function goToAdjacentSection(direction) {
      const currentIndex = scriptSections.findIndex((section) => section.id === currentSection.id);
      if (currentIndex === -1) return;

      let nextIndex = currentIndex + direction;

      while (nextIndex >= 0 && nextIndex < scriptSections.length) {
        const nextSection = scriptSections[nextIndex];

        if (isSectionRelevantForRoute(nextSection)) {
          renderSection(nextSection);
          return;
        }

        nextIndex += direction;
      }

      return;
    }

    function startCall() {
      clearCallSession();
    }

    function clearCallSession() {
      sessionState = createFreshSession();

      if (clientNameInput) clientNameInput.value = "";
      if (clientStateInput) clientStateInput.value = "";
      if (beneficiaryNameInput) beneficiaryNameInput.value = "";
      if (cockpitClientNameInput) cockpitClientNameInput.value = "";
      if (cockpitPersonNameInput) cockpitPersonNameInput.value = "";
      if (cockpitWhyInput) cockpitWhyInput.value = "";
      if (maritalStatusInput) maritalStatusInput.value = "";
      if (spousePartnerInput) spousePartnerInput.value = "";
      if (childrenInfoInput) childrenInfoInput.value = "";
      if (decisionMakerInput) decisionMakerInput.value = "";
      if (decisionMakerRelationInput) decisionMakerRelationInput.value = "";
      if (reliesOnThemInput) reliesOnThemInput.value = "";
      if (familyContextNotesInput) familyContextNotesInput.value = "";
      if (lossExperienceNotesInput) lossExperienceNotesInput.value = "";
      if (funeralConcernInput) funeralConcernInput.value = "";
      if (debtsInput) debtsInput.value = "";
      if (householdBillsInput) householdBillsInput.value = "";
      if (dependentsInput) dependentsInput.value = "";
      if (otherObligationsInput) otherObligationsInput.value = "";
      if (familyResponsibilityNotesInput) familyResponsibilityNotesInput.value = "";
      if (currentSupportNotesInput) currentSupportNotesInput.value = "";
      if (protectionPriorityNotesInput) protectionPriorityNotesInput.value = "";
      setImpactCardSelectionUI("");
      if (premiumInput) premiumInput.value = "";
      if (draftDateInput) draftDateInput.value = "";
      if (medicalSummaryInput) medicalSummaryInput.value = "";
      if (coverageOption1Input) coverageOption1Input.value = "";
      if (quoteOption1Input) quoteOption1Input.value = "";
      if (coverageOption2Input) coverageOption2Input.value = "";
      if (quoteOption2Input) quoteOption2Input.value = "";
      if (coverageOption3Input) coverageOption3Input.value = "";
      if (quoteOption3Input) quoteOption3Input.value = "";
      if (policyNumberInput) policyNumberInput.value = "";
      if (secondaryPhoneInput) secondaryPhoneInput.value = "";
      if (beneficiaryPhoneInput) beneficiaryPhoneInput.value = "";
      if (callNotes) callNotes.value = "";

      stats.transfers += 1;
      sessionState.started = true;
      sessionState.transferCounted = true;

      resetTimer();
      updateOutcomeDisplay();
      renderSection(scriptSections[0]);
      saveStats();
      updateMetrics();
      saveSession();
      startTimer();
      clientNameInput?.focus();
    }

    function addTransfer() {
      if (sessionState.transferCounted) return;

      stats.transfers += 1;
      sessionState.transferCounted = true;

      saveStats();
      saveSession();
      updateMetrics();
    }

    function addSale(countFromOutcome = false) {
      if (sessionState.saleCounted) return;

      const annualPremium = getAnnualPremium();

      stats.sales += 1;
      stats.apSubmitted += annualPremium;

      sessionState.saleCounted = true;
      sessionState.saleFromOutcome = countFromOutcome;
      sessionState.countedAp = annualPremium;

      saveStats();
      saveSession();
      updateMetrics();
    }

    function adjustOutcomeCounts(previousOutcome, nextOutcome) {
      if (previousOutcome === "Sold") stats.sold = Math.max(0, stats.sold - 1);
      if (previousOutcome === "Callback") stats.callback = Math.max(0, stats.callback - 1);
      if (previousOutcome === "Not Interested") stats.notInterested = Math.max(0, stats.notInterested - 1);
      if (previousOutcome === "Medical DQ") stats.medicalDQ = Math.max(0, stats.medicalDQ - 1);

      if (nextOutcome === "Sold") stats.sold += 1;
      if (nextOutcome === "Callback") stats.callback += 1;
      if (nextOutcome === "Not Interested") stats.notInterested += 1;
      if (nextOutcome === "Medical DQ") stats.medicalDQ += 1;
    }

    function setOutcome(nextOutcome) {
      const previousOutcome = sessionState.outcome;

      if (previousOutcome === nextOutcome) return;

      adjustOutcomeCounts(previousOutcome, nextOutcome);

      if (previousOutcome === "Sold" && sessionState.saleFromOutcome) {
        stats.sales = Math.max(0, stats.sales - 1);
        stats.apSubmitted = Math.max(0, stats.apSubmitted - sessionState.countedAp);
        sessionState.saleCounted = false;
        sessionState.saleFromOutcome = false;
        sessionState.countedAp = 0;
      }

      sessionState.outcome = nextOutcome;

      if (nextOutcome === "Sold" && !sessionState.saleCounted) {
        addSale(true);
      } else {
        saveStats();
        saveSession();
        updateMetrics();
      }

      updateOutcomeDisplay();
    }

    function renderRebuttalList(items) {
      if (!objectionResults) return;

      objectionResults.innerHTML = "";

      if (!items.length) {
        const empty = document.createElement("div");
        empty.className = "rounded-lg border border-gray-800 bg-gray-950 px-3 py-3 text-sm text-gray-400";
        empty.textContent = "No matching objections found.";
        objectionResults.appendChild(empty);
        return;
      }

      items.forEach((item) => {
        const button = document.createElement("button");
        button.type = "button";
        button.className =
          "rebuttal-result-button block w-full rounded-lg border border-gray-800 bg-gray-950 px-3 py-2 text-left text-sm text-gray-200 hover:bg-gray-800";
        button.dataset.rebuttalId = String(item.id);

        const title = document.createElement("div");
        title.className = "font-semibold";
        title.textContent = item.title;

        const category = document.createElement("div");
        category.className = "mt-1 text-xs text-gray-400";
        category.textContent = item.category;

        button.appendChild(title);
        button.appendChild(category);

        button.addEventListener("click", () => selectRebuttal(item.id));

        objectionResults.appendChild(button);
      });
    }

    function selectRebuttal(rebuttalId) {
      const rebuttal = rebuttals.find((item) => item.id === Number(rebuttalId));
      if (!rebuttal) return;

      activeRebuttalId = Number(rebuttalId);
      const response = applyTokens(rebuttal.response, getTokens());

      if (selectedRebuttalTitle) {
        selectedRebuttalTitle.textContent = rebuttal.title;
      }

      if (selectedRebuttalBody) {
        selectedRebuttalBody.textContent = response;
      }

      if (inlineSelectedRebuttalTitle) {
        inlineSelectedRebuttalTitle.textContent = rebuttal.title;
      }

      if (inlineSelectedRebuttalBody) {
        inlineSelectedRebuttalBody.textContent = response;
      }
    }

    function openObjectionsWithRebuttal(rebuttalId) {
      showObjectionsPanel(true);
      selectRebuttal(rebuttalId);
    }

    function showObjectionsPanel(focusSearch = false) {
      if (!objectionsPanel) return;

      objectionsPanel.classList.remove("hidden");
      objectionsPanel.scrollIntoView({
        behavior: "smooth",
        block: "start"
      });

      if (focusSearch) {
        window.setTimeout(() => {
          objectionSearch?.focus();
        }, 120);
      }
    }

    function hideObjectionsPanel() {
      objectionsPanel?.classList.add("hidden");
    }

    function setRecommendedQuote(optionNumber) {
      sessionState.recommendedQuote = optionNumber;
      renderSection(currentSection);
    }

    function useQuoteAsPremium(optionNumber) {
      const quoteValue = getQuoteValue(optionNumber);
      if (!quoteValue || !premiumInput) return;

      premiumInput.value = formatMoneyDisplay(quoteValue, quoteValue);
      syncCountedApWithPremium();
      renderSection(currentSection);
      saveSession();
    }

    function filterRebuttals(query) {
      const normalized = query.trim().toLowerCase();

      if (!normalized) {
        renderRebuttalList(rebuttals.slice(0, 10));
        return;
      }

      const results = rebuttals.filter((item) => {
        const haystack = [item.title, item.category, item.response, ...(item.keywords || [])]
          .join(" ")
          .toLowerCase();

        return haystack.includes(normalized);
      });

      renderRebuttalList(results.slice(0, 20));
    }

    function isTypingInField(target) {
      if (!(target instanceof HTMLElement)) return false;
      const tag = target.tagName.toLowerCase();
      return tag === "input" || tag === "textarea" || target.isContentEditable;
    }

    function openSettings() {
      settingsModal?.classList.remove("hidden");
      settingsModal?.classList.add("flex");
    }

    function closeSettings() {
      settingsModal?.classList.add("hidden");
      settingsModal?.classList.remove("flex");
    }

    function saveSettingsFromForm() {

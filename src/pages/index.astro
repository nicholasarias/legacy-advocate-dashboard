    function formatCurrency(value) {
      return `$${Number(value || 0).toFixed(2)}`;
    }

    function parsePremium(value) {
      const cleaned = String(value || "").replace(/[^0-9.]/g, "");
      const parsed = Number(cleaned);
      return Number.isFinite(parsed) ? parsed : 0;
    }

    function getAnnualPremium() {
      return parsePremium(premiumInput?.value) * 12;
    }

    function formatMoneyDisplay(value, fallback = "") {
      const text = String(value || "").trim();
      if (!text) return fallback;

      const parsed = Number(text.replace(/[^0-9.]/g, ""));
      if (!Number.isFinite(parsed) || parsed <= 0) {
        return text;
      }

      return formatCurrency(parsed);
    }

    function formatCoverageDisplay(value, fallback = "") {
      const text = String(value || "").trim();
      if (!text) return fallback;

      const parsed = Number(text.replace(/[^0-9.]/g, ""));
      if (!Number.isFinite(parsed) || parsed <= 0) {
        return text;
      }

      return `$${parsed.toLocaleString("en-US", {
        minimumFractionDigits: 0,
        maximumFractionDigits: 0
      })}`;
    }

    function getClientLastName() {
      const fullName = clientNameInput?.value.trim() || "";
      if (!fullName) return "Client";

      const parts = fullName.split(/\s+/).filter(Boolean);
      return parts.at(-1) || fullName;
    }

    function getBeneficiaryRelationshipLabel() {
      const relation = getBranchSelection("relationType");

      if (relation === "spouse") return "spouse";
      if (relation === "child") return "child";
      if (relation === "sibling") return "sibling";

      return "beneficiary";
    }

    function getProductOutcomeMeta() {
      const productOutcome = getBranchSelection("productOutcome");

      if (productOutcome === "easy-life") {
        return {
          label: "EMC Easy Life",
          carrierName: "EMC National Life",
          policyLabel: "policy",
          customerExperiencePhone: "1-866-699-9099"
        };
      }

      if (productOutcome === "emc-graded") {
        return {
          label: "EMC Graded",
          carrierName: "EMC National Life",
          policyLabel: "policy",
          customerExperiencePhone: "1-866-699-9099"
        };
      }

      if (productOutcome === "eternal-legacy") {
        return {
          label: "Eternal Legacy",
          carrierName: "Monitor Life / Foresters Financial",
          policyLabel: "certificate",
          customerExperiencePhone: "1-866-699-9099"
        };
      }

      return {
        label: "No Option",
        carrierName: "Insurance Carrier",
        policyLabel: "policy",
        customerExperiencePhone: "1-866-699-9099"
      };
    }

    function getQuoteValue(optionNumber) {
      if (optionNumber === "1") return quoteOption1Input?.value.trim() || "";
      if (optionNumber === "2") return quoteOption2Input?.value.trim() || "";
      if (optionNumber === "3") return quoteOption3Input?.value.trim() || "";
      return "";
    }

    function getCoverageValue(optionNumber) {
      if (optionNumber === "1") return coverageOption1Input?.value.trim() || "";
      if (optionNumber === "2") return coverageOption2Input?.value.trim() || "";
      if (optionNumber === "3") return coverageOption3Input?.value.trim() || "";
      return "";
    }

    function applyPricingTokens(value) {
      return String(value || "")
        .replaceAll("[BeneficiaryName]", getAdvisorFocusName())
        .replaceAll("[PrimaryConcern]", getPrimaryConcern());
    }

    function getPricePresentationRouteOption() {
      const pricePresentationSection = scriptSections.find((section) => section.id === 20);
      const branch = pricePresentationSection?.branchControl;

      if (!branch) return null;

      return (
        branch.options.find((option) => option.value === getBranchSelection(branch.stateKey)) || null
      );
    }

    function getRawPriceComparisonOptions() {
      const routeOption = getPricePresentationRouteOption();
      return Array.isArray(routeOption?.comparisonOptions) ? routeOption.comparisonOptions : [];
    }

    function getPriceComparisonOptions() {
      return getRawPriceComparisonOptions().map((option) => ({
        ...option,
        label: applyPricingTokens(option.label),
        title: applyPricingTokens(option.title),
        subtitle: applyPricingTokens(option.subtitle),
        bucketText: applyPricingTokens(option.bucketText),
        badge: applyPricingTokens(option.badge || "")
      }));
    }

    function getRecommendedPricingOptionNumber() {
      return (
        getRawPriceComparisonOptions().find((option) => option.recommendation)?.value ||
        sessionState.recommendedQuote ||
        "2"
      );
    }

    function formatDailyMathDisplay(value) {
      const parsed = parsePremium(value);
      if (!parsed) return "Daily math will appear here.";

      return `About ${formatCurrency(parsed / 30)}/day`;
    }

    function getRecommendedQuoteText() {
      const recommendedQuote = getRecommendedPricingOptionNumber();
      const quoteValue = getQuoteValue(recommendedQuote);
      const coverageValue = getCoverageValue(recommendedQuote);
      const recommendedMeta = getPriceComparisonOptions().find(
        (option) => option.value === recommendedQuote
      );

      if (recommendedQuote && quoteValue && coverageValue) {
        return `${recommendedMeta?.label || `Option ${recommendedQuote}`} at ${formatMoneyDisplay(
          quoteValue,
          quoteValue
        )} for ${formatCoverageDisplay(coverageValue, coverageValue)} in coverage`;
      }

      if (recommendedQuote && quoteValue) {
        return `${recommendedMeta?.label || `Option ${recommendedQuote}`} at ${formatMoneyDisplay(
          quoteValue,
          quoteValue
        )}`;
      }

      if (recommendedQuote) {
        return recommendedMeta?.label || `Option ${recommendedQuote}`;
      }

      return "Option 2";
    }


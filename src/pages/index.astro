      if (sectionId === 3) {
        discoveryPanelTitle.textContent = "The Person";
        discoveryPanelText.textContent =
          "Use their name quickly so the conversation stays grounded in one real person.";
        familyContextGroup?.classList.remove("hidden");
        return;
      }

      if (sectionId === 4) {
        discoveryPanelTitle.textContent = "Life Experiences With Loss";
        discoveryPanelText.textContent =
          "Be warm here, but keep it gentle and brief.";
        lossExperienceGroup?.classList.remove("hidden");
        return;
      }

      if (sectionId === 5) {
        discoveryPanelTitle.textContent = "The First 90 Days";
        discoveryPanelText.textContent =
          "Let them picture the first few months, not just the funeral bill.";
        familyResponsibilityGroup?.classList.remove("hidden");
        return;
      }

      if (sectionId === 6) {
        discoveryPanelTitle.textContent = "Support & Priorities";
        discoveryPanelText.textContent =
          "Capture what is already set aside and the one pressure point they most want handled.";
        currentSupportGroup?.classList.remove("hidden");
        protectionPriorityGroup?.classList.remove("hidden");
        return;
      }

      if (sectionId === 7) {
        discoveryPanelTitle.textContent = "Advisor Bridge";
        discoveryPanelText.textContent =
          "Summarize the person and the pressure point before you pivot.";
        protectionPriorityGroup?.classList.remove("hidden");
        discoveryBridgeGroup?.classList.remove("hidden");
        return;

    function updateBridgePrioritySummary() {
      if (!bridgePrioritySummary) return;

      const prioritySummary = getPrimaryConcern();
      const personName = getAdvisorFocusName();

      bridgePrioritySummary.textContent =
        prioritySummary === "those first expenses"

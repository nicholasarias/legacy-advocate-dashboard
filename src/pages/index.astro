        renderSection(currentSection);
        return;
      }

      if (source !== "inline") {
        updateDiscoveryInlineNotes(currentSection);
      }
      updateAdvisorCockpit(currentSection);
      updateDiscoveryWorkspace(currentSection);
      saveSession();
    }


    function configureCockpitLayout() {
      if (hudColumn && scriptPanel && scriptPanel.parentElement !== hudColumn) {
        hudColumn.appendChild(scriptPanel);
      }

      if (secondaryRail) {
        [pricingActionPanel, discoveryWorkspacePanel, promptPanel, advisorCapturePanel, salesWorkspacePanel]
          .filter((panel) => panel instanceof HTMLElement)
          .forEach((panel) => {
            if (panel.parentElement !== secondaryRail) {
              secondaryRail.appendChild(panel);
            }
          });
      }

      if (toolkitColumn) {
        [shortcutsPanel]
          .filter((panel) => panel instanceof HTMLElement)
          .forEach((panel) => {
            if (panel.parentElement !== toolkitColumn) {
              toolkitColumn.appendChild(panel);
            }
          });
      }
    }

    function isAtOrAfterPricePresentation(section = currentSection) {
      return Number(section?.id ?? 0) >= PRICE_PRESENTATION_SECTION_ID;
    }

    function getObjectionStageGroup(section = currentSection) {
      return isAtOrAfterPricePresentation(section) ? "late" : "early";
    }

    function isRebuttalRelevantForSection(rebuttal, section = currentSection) {
      if (!rebuttal) return false;

      const sectionId = Number(section?.id ?? 0);

      if (rebuttal.stageGroup !== getObjectionStageGroup(section)) {
        return false;
      }

      if (Array.isArray(rebuttal.sectionIds) && rebuttal.sectionIds.length) {
        return rebuttal.sectionIds.includes(sectionId);
      }

      if (Array.isArray(rebuttal.sectionRange) && rebuttal.sectionRange.length === 2) {
        return sectionId >= rebuttal.sectionRange[0] && sectionId <= rebuttal.sectionRange[1];
      }

      return true;
    }

    function getRelevantRebuttals(section = currentSection) {
      return rebuttals.filter((item) => isRebuttalRelevantForSection(item, section));
    }

    function getRelevantFavoriteRebuttals(section = currentSection) {
      return getRelevantRebuttals(section).filter((item) => item.favorite);
    }

    function updatePromptPanelPlacement(section = currentSection) {
      if (!secondaryRail || !promptPanel) {
        return;
      }

      const afterPricing = isAtOrAfterPricePresentation(section);

      promptPanel.classList.toggle("prompt-panel-secondary", afterPricing);

      if (afterPricing) {
        if (promptPanel.parentElement !== secondaryRail || promptPanel !== secondaryRail.lastElementChild) {
          secondaryRail.appendChild(promptPanel);
        }
        return;
      }

      if (promptPanel.parentElement !== secondaryRail || promptPanel !== secondaryRail.firstElementChild) {
        secondaryRail.prepend(promptPanel);
      }
    }

    function shouldDockObjectionsPanel(section = currentSection) {
      return Boolean(
        section?.id === 20 &&
          getBranchSelection("productOutcome") !== "no-option" &&
          objectionsPanel &&
          pricingObjectionsPanelHost &&
          secondaryRail
      );
    }

    function isObjectionsDockedInPricing() {
      return Boolean(
        pricingObjectionsPanelHost &&
          objectionsPanel &&
          objectionsPanel.parentElement === pricingObjectionsPanelHost
      );
    }

    function updateObjectionsPlacement(section = currentSection) {
      if (!objectionsPanel || !secondaryRail || !pricingObjectionsPanelHost) {
        return;
      }

      const dockInPricing = shouldDockObjectionsPanel(section);
      const targetParent = dockInPricing ? pricingObjectionsPanelHost : secondaryRail;

      if (objectionsPanel.parentElement !== targetParent) {
        targetParent.appendChild(objectionsPanel);
      }

      if (!dockInPricing) {
        const afterPricing = isAtOrAfterPricePresentation(section);

        if (afterPricing) {
          if (promptPanel?.parentElement === secondaryRail) {
            secondaryRail.insertBefore(objectionsPanel, promptPanel);
          } else if (secondaryRail.firstElementChild !== objectionsPanel) {
            secondaryRail.prepend(objectionsPanel);
          }
        } else if (promptPanel?.parentElement === secondaryRail) {
          if (promptPanel.nextElementSibling !== objectionsPanel) {
            promptPanel.insertAdjacentElement("afterend", objectionsPanel);
          }
        } else if (secondaryRail.firstElementChild !== objectionsPanel) {
          secondaryRail.prepend(objectionsPanel);
        }
      }

      objectionsPanel.classList.toggle("objections-panel-docked", dockInPricing);
      pricingObjectionsPanelHost.classList.toggle(
        "hidden",
        !dockInPricing || objectionsPanel.classList.contains("hidden")
      );
    }

    function updateToolkitVisibility() {
      if (!workflowGrid || !toolkitColumn) return;

      const visiblePanels = Array.from(toolkitColumn.children).filter((child) => {

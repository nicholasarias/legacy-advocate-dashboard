      if (!suggestedObjectionTriggerKey) {
        objectionSuggestionBadge.classList.add("hidden");
        return;
      }

      const definition = objectionTriggerDefinitionMap[suggestedObjectionTriggerKey];

      if (!definition) {
        objectionSuggestionBadge.classList.add("hidden");
        return;
      }

      objectionSuggestionBadge.textContent = `Suggested: ${definition.label}`;
      objectionSuggestionBadge.classList.remove("hidden");

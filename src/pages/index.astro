  <script define:vars={{ scriptSections, rebuttals }}>
    const SETTINGS_STORAGE_KEY = "legacy_dashboard_settings_v2";
    const STATS_STORAGE_KEY = "legacy_dashboard_stats_v7";
    const SESSION_STORAGE_KEY = "legacy_dashboard_session_v5";
    const TALK_SIGNAL_WORDS = ["talk", "ask", "speak", "check", "run"];
    const SPOUSE_SIGNAL_WORDS = ["spouse", "wife", "husband"];
    const FAMILY_SIGNAL_WORDS = [
      "family",
      "son",
      "daughter",
      "brother",
      "sister",
      "kids",
      "children",
      "mom",
      "dad",
      "mother",
      "father",
      "parents"
    ];
    const objectionTriggerDefinitions = [
      {
        key: "think-about-it",
        label: "Think About It",
        rebuttalIds: {
          early: 108,
          late: 203
        },
        resultQueries: {
          early: "think about it later",
          late: "need to think about it"
        },
        phrases: ["think about it", "let me think", "sleep on it", "think it over", "later", "tomorrow"]
      },
      {
        key: "price",
        label: "Price",
        rebuttalIds: {
          early: 113,
          late: 201
        },
        resultQueries: {
          early: "price concern",
          late: "too expensive"
        },
        phrases: ["too much", "too expensive", "can t afford", "cant afford", "expensive", "price", "cost"],
        terms: ["afford", "cheaper", "monthly"]
      },
      {
        key: "already-covered",
        label: "Already Covered",
        rebuttalIds: {
          early: 101,
          late: 202
        },
        resultQueries: {
          early: "already have coverage",
          late: "already have insurance"
        },
        phrases: ["already have", "already covered", "already insured", "have insurance", "have life insurance"],
        terms: ["policy", "covered", "insurance"]
      },
      {
        key: "spouse",
        label: "Spouse",
        rebuttalIds: {
          early: 109,
          late: 204
        },
        resultQueries: {
          early: "talk to spouse",
          late: "talk to spouse"
        },
        phrases: ["talk to my spouse", "talk to my wife", "talk to my husband", "my spouse", "my wife", "my husband"],
        terms: ["spouse", "wife", "husband"],
        matcher: "spouse-talk"
      },
      {
        key: "call-back",
        label: "Call Back",
        rebuttalIds: {
          early: 105,
          late: 207
        },
        resultQueries: {
          early: "busy right now",
          late: "call me back"
        },
        phrases: ["call me back", "call back", "callback", "another time", "later today"]
      },
      {
        key: "need-to-pray",
        label: "Need To Pray",
        rebuttalIds: {
          early: 111,
          late: 206
        },
        resultQueries: {
          early: "need to pray about it",
          late: "need to pray about it"
        },
        phrases: ["need to pray", "want to pray", "pray about it", "prayer"],
        terms: ["pray", "prayer"]
      },
      {
        key: "need-to-talk-to-family",
        label: "Need To Talk To Family",
        rebuttalIds: {
          early: 110,
          late: 205
        },
        resultQueries: {
          early: "talk to family",
          late: "talk to family"
        },
        phrases: ["talk to family", "talk to my family", "ask family", "need to ask my family"],
        matcher: "family-talk"
      },
      {
        key: "not-sure",
        label: "Not Sure",
        rebuttalIds: {
          early: 114,
          late: 213
        },
        resultQueries: {
          early: "not sure",
          late: "not sure"
        },
        phrases: ["not sure", "unsure", "do not know", "don t know", "dont know", "not certain"]
      },
      {
        key: "employer-coverage",
        label: "Employer Coverage",
        rebuttalIds: {
          early: 102,
          late: 209
        },
        resultQueries: {
          early: "through work already",
          late: "employer coverage"
        },
        phrases: ["through work", "through my job", "job coverage", "work coverage", "employer coverage", "employee benefits"],
        terms: ["employer", "benefits", "job"]
      },
      {
        key: "term-policy",
        label: "Term Policy",
        rebuttalIds: {
          early: 112,
          late: 210
        },
        resultQueries: {
          early: "term policy",
          late: "term policy"
        },
        phrases: ["term policy", "term life", "term insurance"],
        terms: ["term"]
      }
    ];
    const objectionTriggerDefinitionMap = Object.fromEntries(
      objectionTriggerDefinitions.map((definition) => [definition.key, definition])
    );

    function createEmptyBranchSelections() {
      return {
        coverageStatus: "",
        closeResponseFlow: "",
        fundingStatus: "",
        funeralExperience: "",
        arrangementPreference: "",
        relationType: "",
        lossExperience: "",
        bridgeStyle: "",
        medicalReview: "",
        productOutcome: ""
      };
    }

    function todayKey() {
      const now = new Date();
      const year = now.getFullYear();
      const month = String(now.getMonth() + 1).padStart(2, "0");
      const day = String(now.getDate()).padStart(2, "0");
      return `${year}-${month}-${day}`;
    }

    function createDefaultSettings() {
      return {
        advisorName: "Nick Arias",
        advisorPhone: "YOUR_PHONE",
        advisorNPN: "YOUR_NPN",
        dailySalesGoal: 8,
        apGoal: 3000
      };
    }

    function createFreshStats() {
      return {
        date: todayKey(),
        totalCalls: 0,
        transfers: 0,
        sales: 0,
        sold: 0,
        callback: 0,
        notInterested: 0,
        medicalDQ: 0,
        apSubmitted: 0
      };
    }

    function createFreshDiscoveryData() {
      return {
        maritalStatus: "",
        spousePartner: "",
        childrenInfo: "",
        decisionMaker: "",
        primaryConcern: "",
        reliesOnThem: "",
        familyContextNotes: "",
        lossExperienceNotes: "",
        funeralConcern: "",
        debtConcerns: "",
        householdBills: "",
        dependentsConcern: "",
        otherObligations: "",
        familyResponsibilityNotes: "",
        currentSupportNotes: "",
        protectionPriorities: [],
        protectionPriorityNotes: ""
      };
    }

    function createFreshSession() {
      return {
        currentSectionId: scriptSections[0]?.id ?? 1,
        notes: "",
        outcome: "",
        clientName: "",
        clientState: "",
        beneficiaryName: "",
        premium: "",
        draftDate: "",
        medicalSummary: "",
        coverageOption1: "",
        quoteOption1: "",
        coverageOption2: "",
        quoteOption2: "",
        coverageOption3: "",
        quoteOption3: "",
        recommendedQuote: "",
        selectedPricingOption: "",
        selectedCoverageAmount: "",
        policyNumber: "",
        secondaryPhone: "",
        beneficiaryPhone: "",
        started: false,
        transferCounted: false,
        saleCounted: false,
        saleFromOutcome: false,
        countedAp: 0,
        discovery: createFreshDiscoveryData(),
        branchSelections: createEmptyBranchSelections()
      };
    }

    function loadSettings() {
      const raw = localStorage.getItem(SETTINGS_STORAGE_KEY);

      if (!raw) return createDefaultSettings();

      try {
        const parsed = JSON.parse(raw);
        return {
          advisorName: String(parsed.advisorName ?? "Nick Arias"),
          advisorPhone: String(parsed.advisorPhone ?? "YOUR_PHONE"),
          advisorNPN: String(parsed.advisorNPN ?? "YOUR_NPN"),
          dailySalesGoal: Number(parsed.dailySalesGoal ?? 8),
          apGoal: Number(parsed.apGoal ?? 3000)
        };
      } catch {
        return createDefaultSettings();
      }
    }

    function loadStats() {
      const raw = localStorage.getItem(STATS_STORAGE_KEY);

      if (!raw) return createFreshStats();

      try {
        const parsed = JSON.parse(raw);

        if (!parsed || parsed.date !== todayKey()) {
          return createFreshStats();
        }

        return {
          date: parsed.date ?? todayKey(),
          totalCalls: Number(parsed.totalCalls ?? 0),
          transfers: Number(parsed.transfers ?? 0),
          sales: Number(parsed.sales ?? 0),
          sold: Number(parsed.sold ?? 0),
          callback: Number(parsed.callback ?? 0),
          notInterested: Number(parsed.notInterested ?? 0),
          medicalDQ: Number(parsed.medicalDQ ?? 0),
          apSubmitted: Number(parsed.apSubmitted ?? 0)
        };
      } catch {
        return createFreshStats();
      }
    }

    function loadSession() {
      const raw = sessionStorage.getItem(SESSION_STORAGE_KEY);

      if (!raw) return createFreshSession();

      try {
        const parsed = JSON.parse(raw);
        const parsedBranchSelections =
          parsed.branchSelections && typeof parsed.branchSelections === "object"
            ? parsed.branchSelections
            : {};
        const parsedDiscovery =
          parsed.discovery && typeof parsed.discovery === "object" ? parsed.discovery : {};
        const decisionMaker = String(parsedDiscovery.decisionMaker ?? parsed.beneficiaryName ?? "");
        const parsedSectionId = Number(parsed.currentSectionId ?? (scriptSections[0]?.id ?? 1));
        const currentSectionId = parsedSectionId === 9 ? 10 : parsedSectionId;

        return {
          currentSectionId,
          notes: String(parsed.notes ?? parsedDiscovery.familyContextNotes ?? ""),
          outcome: String(parsed.outcome ?? ""),
          clientName: String(parsed.clientName ?? ""),
          clientState: String(parsed.clientState ?? ""),
          beneficiaryName: String(parsed.beneficiaryName ?? decisionMaker),
          premium: String(parsed.premium ?? ""),
          draftDate: String(parsed.draftDate ?? ""),
          medicalSummary: String(parsed.medicalSummary ?? ""),
          coverageOption1: String(parsed.coverageOption1 ?? ""),
          quoteOption1: String(parsed.quoteOption1 ?? ""),
          coverageOption2: String(parsed.coverageOption2 ?? ""),
          quoteOption2: String(parsed.quoteOption2 ?? ""),
          coverageOption3: String(parsed.coverageOption3 ?? ""),
          quoteOption3: String(parsed.quoteOption3 ?? ""),
          recommendedQuote: String(parsed.recommendedQuote ?? ""),
          selectedPricingOption: String(parsed.selectedPricingOption ?? ""),
          selectedCoverageAmount: String(parsed.selectedCoverageAmount ?? ""),
          policyNumber: String(parsed.policyNumber ?? ""),
          secondaryPhone: String(parsed.secondaryPhone ?? ""),
          beneficiaryPhone: String(parsed.beneficiaryPhone ?? ""),
          started: Boolean(parsed.started ?? false),
          transferCounted: Boolean(parsed.transferCounted ?? false),
          saleCounted: Boolean(parsed.saleCounted ?? false),
          saleFromOutcome: Boolean(parsed.saleFromOutcome ?? false),
          countedAp: Number(parsed.countedAp ?? 0),
          discovery: {
            maritalStatus: String(parsedDiscovery.maritalStatus ?? ""),
            spousePartner: String(parsedDiscovery.spousePartner ?? ""),
            childrenInfo: String(parsedDiscovery.childrenInfo ?? ""),
            decisionMaker,
            primaryConcern: String(
              parsedDiscovery.primaryConcern ??
                (Array.isArray(parsedDiscovery.protectionPriorities)
                  ? parsedDiscovery.protectionPriorities[0] ?? ""
                  : "")
            ),
            reliesOnThem: String(parsedDiscovery.reliesOnThem ?? ""),
            familyContextNotes: String(parsedDiscovery.familyContextNotes ?? parsed.notes ?? ""),
            lossExperienceNotes: String(parsedDiscovery.lossExperienceNotes ?? ""),
            funeralConcern: String(parsedDiscovery.funeralConcern ?? ""),
            debtConcerns: String(parsedDiscovery.debtConcerns ?? ""),
            householdBills: String(parsedDiscovery.householdBills ?? ""),
            dependentsConcern: String(parsedDiscovery.dependentsConcern ?? ""),
            otherObligations: String(parsedDiscovery.otherObligations ?? ""),
            familyResponsibilityNotes: String(parsedDiscovery.familyResponsibilityNotes ?? ""),
            currentSupportNotes: String(parsedDiscovery.currentSupportNotes ?? ""),
            protectionPriorities: Array.isArray(parsedDiscovery.protectionPriorities)
              ? parsedDiscovery.protectionPriorities.map((value) => String(value))
              : [],
            protectionPriorityNotes: String(parsedDiscovery.protectionPriorityNotes ?? "")
          },
          branchSelections: {
            coverageStatus: String(parsedBranchSelections.coverageStatus ?? ""),
            fundingStatus: String(
              parsedBranchSelections.fundingStatus ??
                (["set-aside", "would-scramble"].includes(
                  String(parsedBranchSelections.coverageStatus ?? "")
                )
                  ? parsedBranchSelections.coverageStatus
                  : "")
            ),
            funeralExperience: String(
              parsedBranchSelections.funeralExperience ?? parsedBranchSelections.lossExperience ?? ""
            ),
            arrangementPreference: String(parsedBranchSelections.arrangementPreference ?? ""),
            relationType: String(parsedBranchSelections.relationType ?? parsed.relationType ?? ""),
            lossExperience: String(
              parsedBranchSelections.lossExperience ?? parsedBranchSelections.funeralExperience ?? ""
            ),
            bridgeStyle: String(parsedBranchSelections.bridgeStyle ?? ""),
            closeResponseFlow: String(parsedBranchSelections.closeResponseFlow ?? ""),
            medicalReview: String(parsedBranchSelections.medicalReview ?? ""),
            productOutcome: String(parsedBranchSelections.productOutcome ?? "")
          }
        };
      } catch {
        return createFreshSession();
      }
    }

    function saveSettings() {
      localStorage.setItem(SETTINGS_STORAGE_KEY, JSON.stringify(settings));
    }


      setDiscoveryField("protectionPriorityNotes", protectionPriorityNotesInput.value, true);
    });

    cockpitWhyInput?.addEventListener("input", () => {
      sessionState.discovery = {
        ...sessionState.discovery,
        primaryConcern: cockpitWhyInput.value,
        protectionPriorities: [],
        protectionPriorityNotes: cockpitWhyInput.value
      };

      if (protectionPriorityNotesInput && protectionPriorityNotesInput.value !== cockpitWhyInput.value) {
        protectionPriorityNotesInput.value = cockpitWhyInput.value;
      }

      renderSection(currentSection);
    });

    discoveryInlineNotesInput?.addEventListener("input", () => {
      const discoveryKey = discoveryInlineNotesInput.dataset.discoveryKey || "";
      if (!discoveryKey) return;

      const linkedField = getDiscoveryNotesFieldByKey(discoveryKey);
      if (linkedField && linkedField.value !== discoveryInlineNotesInput.value) {
        linkedField.value = discoveryInlineNotesInput.value;
      }

      setDiscoveryField(discoveryKey, discoveryInlineNotesInput.value, false, "inline");
    });

    impactCards.forEach((card) => {
      card.addEventListener("click", () => {
        if (!(card instanceof HTMLElement)) return;

        const nextValue = card.dataset.impactValue || "";
        const selectedValue = sessionState.discovery?.primaryConcern === nextValue ? "" : nextValue;

        sessionState.discovery = {
          ...sessionState.discovery,
          primaryConcern: selectedValue,
          protectionPriorities: selectedValue ? [selectedValue] : []
        };

        renderSection(currentSection);
      });
    });

    draftDateInput?.addEventListener("change", () => {
      renderSection(currentSection);
      saveSession();
    });

    premiumInput?.addEventListener("input", () => {
      sessionState.premium = premiumInput.value;
      syncCountedApWithPremium();
      renderSection(currentSection);
      saveSession();
    });

    [medicalSummaryInput, policyNumberInput, secondaryPhoneInput, beneficiaryPhoneInput].forEach(
      (input) => {
        input?.addEventListener("input", () => {
          renderSection(currentSection);
          saveSession();
        });
      }
    );

    [
      coverageOption1Input,
      quoteOption1Input,
      coverageOption2Input,
      quoteOption2Input,
      coverageOption3Input,
      quoteOption3Input
    ].forEach((input) => {
      input?.addEventListener("input", () => {
        syncSelectedPricingChoiceFromInputs();
        renderSection(currentSection);
        saveSession();
      });
    });

    quoteCards.forEach((card) => {
      if (!(card instanceof HTMLElement)) return;

      const optionNumber = card.dataset.quoteCard || "";

      card.addEventListener("click", () => {
        if (!optionNumber) return;
        selectQuoteOption(optionNumber);
      });

      card.addEventListener("keydown", (event) => {
        if (isTypingInField(event.target)) return;
        if (event.key !== "Enter" && event.key !== " ") return;
        event.preventDefault();
        if (!optionNumber) return;
        selectQuoteOption(optionNumber);
      });
    });

    quickObjectionButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (!(button instanceof HTMLElement)) return;
        openObjectionsWithRebuttal(button.dataset.rebuttalId);
      });
    });

    discoveryHandoffButton?.addEventListener("click", () => {
      const nextStepSection = scriptSections.find((section) => section.id === 11);
      if (nextStepSection) {
        renderSection(nextStepSection);
      }
    });

    backButton?.addEventListener("click", () => {
      goToAdjacentSection(-1);
    });

    nextButton?.addEventListener("click", () => {
      goToAdjacentSection(1);
    });

    startCallButton?.addEventListener("click", () => {
      startCall();
    });

    newCallButton?.addEventListener("click", () => {
      clearCallSession();
    });

    markTransferButton?.addEventListener("click", () => {
      addTransfer();
    });

    markSaleButton?.addEventListener("click", () => {
      addSale(false);
    });

    outcomeSoldButton?.addEventListener("click", () => {
      setOutcome("Sold");
    });

    outcomeCallbackButton?.addEventListener("click", () => {
      setOutcome("Callback");
    });

    outcomeNotInterestedButton?.addEventListener("click", () => {
      setOutcome("Not Interested");
    });

    outcomeMedicalDQButton?.addEventListener("click", () => {
      setOutcome("Medical DQ");
    });

    objectionSearch?.addEventListener("input", () => {
      filterRebuttals(objectionSearch.value);
      refreshObjectionTriggerSuggestion();
    });

    objectionTriggerButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (!(button instanceof HTMLElement)) return;
        applyObjectionTrigger(button.dataset.triggerKey || "");
      });
    });

    toggleShortcutsButton?.addEventListener("click", () => {
      shortcutsPanel?.classList.toggle("hidden");
      updateToolkitVisibility();
    });

    toggleObjectionsButton?.addEventListener("click", () => {
      showObjectionsPanel(true);
    });

    closeObjectionsButton?.addEventListener("click", () => {
      hideObjectionsPanel();
    });

    openSettingsButton?.addEventListener("click", () => {
      openSettings();
    });

    closeSettingsButton?.addEventListener("click", () => {
      closeSettings();
    });

    saveSettingsButton?.addEventListener("click", () => {
      saveSettingsFromForm();
    });

    settingsModal?.addEventListener("click", (event) => {
      if (event.target === settingsModal) {
        closeSettings();
      }
    });

    window.addEventListener("keydown", (event) => {
      const typing = isTypingInField(event.target);

      if (event.key === "Escape") {
        hideSectionsDrawer();
        if (!objectionsPanel?.classList.contains("hidden")) {
          hideObjectionsPanel();
        }
      }

      if (event.ctrlKey && event.key.toLowerCase() === "n") {
        event.preventDefault();
        clearCallSession();
        return;
      }

      if (event.ctrlKey && event.key.toLowerCase() === "s") {
        event.preventDefault();
        addSale(false);
        return;
      }

      if (event.altKey && event.key.toLowerCase() === "c") {
        event.preventDefault();
        clientNameInput?.focus();
        return;
      }

      if (event.altKey && event.key.toLowerCase() === "b") {
        event.preventDefault();
        beneficiaryNameInput?.focus();
        return;
      }

      if (!typing && event.key === "ArrowRight") {
        event.preventDefault();
        goToAdjacentSection(1);
        return;
      }

      if (!typing && event.key === "ArrowLeft") {
        event.preventDefault();
        goToAdjacentSection(-1);
      }
    });

    updateSettingsUI();
    updateTimerDisplay();
    updateMetrics();
    updateOutcomeDisplay();
    refreshRebuttalCollections();
    selectRebuttal(activeRebuttalId);
    latestObjectionNoteSignal =
      [
        discoveryInlineNotesInput?.value,
        protectionPriorityNotesInput?.value,
        currentSupportNotesInput?.value,
        familyResponsibilityNotesInput?.value,
        lossExperienceNotesInput?.value,
        familyContextNotesInput?.value
      ]
        .map((value) => String(value || "").trim())
        .find(Boolean) || "";
    refreshObjectionTriggerSuggestion();
    renderSection(currentSection);
  </script>
</Layout>

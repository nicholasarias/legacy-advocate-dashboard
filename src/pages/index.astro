      if (settingsSalesGoal) settingsSalesGoal.value = String(settings.dailySalesGoal);
      if (settingsApGoal) settingsApGoal.value = String(settings.apGoal);
    }

    function updateMetrics() {
      if (totalCallsEl) totalCallsEl.textContent = String(stats.totalCalls);
      if (transfersEl) transfersEl.textContent = String(stats.transfers);
      if (salesEl) salesEl.textContent = String(stats.sales);
      if (salesGoalProgressEl) salesGoalProgressEl.textContent = String(stats.sales);
      if (apSubmittedEl) apSubmittedEl.textContent = formatCurrency(stats.apSubmitted);

      if (soldCountEl) soldCountEl.textContent = String(stats.sold);
      if (callbackCountEl) callbackCountEl.textContent = String(stats.callback);
      if (notInterestedCountEl) notInterestedCountEl.textContent = String(stats.notInterested);
      if (medicalDQCountEl) medicalDQCountEl.textContent = String(stats.medicalDQ);

      const closeRate =
        stats.transfers > 0 ? ((stats.sales / stats.transfers) * 100).toFixed(1) : "0";

      if (closeRateEl) closeRateEl.textContent = `${closeRate}%`;
    }

    function updateOutcomeDisplay() {
      if (currentOutcomeEl) {
        currentOutcomeEl.textContent = sessionState.outcome || "None";
      }
    }

    function syncCountedApWithPremium() {
      if (!sessionState.saleCounted) return;

      const newAnnualPremium = getAnnualPremium();
      const difference = newAnnualPremium - sessionState.countedAp;

      if (difference !== 0) {
        stats.apSubmitted += difference;
        sessionState.countedAp = newAnnualPremium;
        saveStats();
        saveSession();
        updateMetrics();
      }
    }

    function setImpactCardSelectionUI(value) {
      const selectedValue = String(value || "");

      impactCards.forEach((card) => {
        if (!(card instanceof HTMLElement)) return;

        const isActive = card.dataset.impactValue === selectedValue;
        card.classList.toggle("impact-card-active", isActive);
        card.classList.toggle("impact-card-idle", !isActive);
        card.setAttribute("aria-pressed", String(isActive));
      });

      if (primaryConcernReadout) {
        const concernLabel = selectedValue || getPrimaryConcern();
        primaryConcernReadout.textContent =
          concernLabel && concernLabel !== "those first expenses"
            ? `Primary concern: ${concernLabel}`
            : "No primary concern selected yet.";
      }
    }

    function getPrimaryConcern() {
      const selectedConcern = sessionState.discovery?.primaryConcern?.trim() || "";
      if (selectedConcern) return selectedConcern;

      const priorityNotes = sessionState.discovery?.protectionPriorityNotes?.trim() || "";
      if (priorityNotes) return priorityNotes;

      const responsibilityFallback = [
        sessionState.discovery?.funeralConcern?.trim() || "",
        sessionState.discovery?.debtConcerns?.trim() || "",
        sessionState.discovery?.householdBills?.trim() || ""
      ].find(Boolean);

      return responsibilityFallback || "those first expenses";
    }

    function getAdvisorFocusName() {
      return (
        decisionMakerInput?.value.trim() ||
        beneficiaryNameInput?.value.trim() ||
        sessionState.discovery?.decisionMaker?.trim() ||
        "the person they care about most"
      );
    }

    function updateAdvisorCockpit(section = currentSection) {
      const clientName = clientNameInput?.value.trim() || "";
      const focusName = getAdvisorFocusName();
      const defaultFocusName = "the person they care about most";
      const nextPersonValue = focusName === defaultFocusName ? "" : focusName;
      const primaryConcern = getPrimaryConcern();
      const cockpitWhyValue =
        sessionState.discovery?.primaryConcern || sessionState.discovery?.protectionPriorityNotes || "";
      const premiumValue = premiumInput?.value.trim() || "";
      const annualPremium = getAnnualPremium();

      if (cockpitClientNameInput && cockpitClientNameInput.value !== clientName) {
        cockpitClientNameInput.value = clientName;
      }

      if (cockpitPersonNameInput && cockpitPersonNameInput.value !== nextPersonValue) {
        cockpitPersonNameInput.value = nextPersonValue;
      }

      if (cockpitWhyInput && cockpitWhyInput.value !== cockpitWhyValue) {
        cockpitWhyInput.value = cockpitWhyValue;
      }

      if (cockpitStepReadout) {
        cockpitStepReadout.textContent = `Section ${section.id} of ${scriptSections.length}`;
      }

      if (cockpitHudPreview) {
        const nameForPreview = focusName === defaultFocusName ? "them" : focusName;
        cockpitHudPreview.textContent = `What would this mean for ${nameForPreview} if ${primaryConcern} landed on them?`;
      }

      if (premiumEstimateDisplay) {
        premiumEstimateDisplay.textContent = premiumValue
          ? formatMoneyDisplay(premiumValue, premiumValue)
          : "No estimate yet";
      }

      if (premiumEstimateDetail) {
        if (premiumValue) {
          premiumEstimateDetail.textContent = `Annualized premium: ${formatCurrency(annualPremium)}.`;
        } else {
          premiumEstimateDetail.textContent = "Enter or select a premium to populate this estimate.";
        }
      }
    }

    function joinNaturalList(items) {
      if (!items.length) return "";
      if (items.length === 1) return items[0];
      if (items.length === 2) return `${items[0]} and ${items[1]}`;
      return `${items.slice(0, -1).join(", ")}, and ${items.at(-1)}`;
    }

    function getPrioritySummary() {
      const primaryConcern = getPrimaryConcern();
      if (primaryConcern) return primaryConcern;

      const priorities = sessionState.discovery?.protectionPriorities || [];
      if (priorities.length) {
        return joinNaturalList(priorities);
      }

      return "those costs";
    }

    function isDiscoverySection(section) {
      return section.id >= 2 && section.id <= 10;
    }

    function getPrimaryPacingCue(section) {
      const selectedOption = getSelectedBranchOption(section);
      return (
        selectedOption?.promptNotes?.[0] ||
        section.prompt?.notes?.[0] ||
        "Keep this conversational."
